@{
    ViewData["Title"] = "Events";
}

<div class="page-header" style="background: var(--bw-gray);">
    <h1>Events</h1>
    <div class="divider"></div>
    <p style="color: var(--bw-medium-gray);">Join us for special events and activities</p>
</div>

<div class="container py-5">
    <div class="row">
        <div class="col-12 mb-5 text-center">
            <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Upcoming Events</h2>
            <p style="color: var(--bw-medium-gray); font-size: 1.1rem; max-width: 600px; margin: 0 auto;">
                Experience the finest coffee culture through our exclusive events
            </p>
        </div>
    </div>

    <div class="row">
        <!-- Event 1 -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="event-card">
                <div class="event-icon">
                    <i class="fas fa-coffee"></i>
                </div>
                <div class="event-content">
                    <div class="event-date">
                        <i class="fas fa-calendar-alt"></i> Every Saturday
                    </div>
                    <h3>Coffee Tasting Workshop</h3>
                    <p>Join our expert baristas for an interactive coffee tasting experience. Learn about different coffee beans, brewing methods, and flavor profiles.</p>
                    <div class="event-time">
                        <i class="fas fa-clock"></i> 10:00 AM - 12:00 PM
                    </div>
                </div>
            </div>
        </div>

        <!-- Event 2 -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="event-card">
                <div class="event-icon">
                    <i class="fas fa-music"></i>
                </div>
                <div class="event-content">
                    <div class="event-date">
                        <i class="fas fa-calendar-alt"></i> Every Friday
                    </div>
                    <h3>Live Acoustic Night</h3>
                    <p>Enjoy soulful acoustic performances from local artists while sipping on your favorite coffee drinks. Open mic sign-ups available!</p>
                    <div class="event-time">
                        <i class="fas fa-clock"></i> 7:00 PM - 10:00 PM
                    </div>
                </div>
            </div>
        </div>

        <!-- Event 3 -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="event-card">
                <div class="event-icon">
                    <i class="fas fa-leaf"></i>
                </div>
                <div class="event-content">
                    <div class="event-date">
                        <i class="fas fa-calendar-alt"></i> First Sunday of Month
                    </div>
                    <h3>Sustainable Coffee Day</h3>
                    <p>Learn about sustainable coffee farming practices and our commitment to ethical sourcing. Plant a tree with us!</p>
                    <div class="event-time">
                        <i class="fas fa-clock"></i> 9:00 AM - 1:00 PM
                    </div>
                </div>
            </div>
        </div>

        <!-- Event 4 -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="event-card">
                <div class="event-icon">
                    <i class="fas fa-birthday-cake"></i>
                </div>
                <div class="event-content">
                    <div class="event-date">
                        <i class="fas fa-calendar-alt"></i> Monthly
                    </div>
                    <h3>Birthday Special</h3>
                    <p>Celebrate your birthday month with us! Get a free drink and pastry when you visit during your birthday week.</p>
                    <div class="event-time">
                        <i class="fas fa-clock"></i> All Day
                    </div>
                </div>
            </div>
        </div>

        <!-- Event 5 -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="event-card">
                <div class="event-icon">
                    <i class="fas fa-laptop"></i>
                </div>
                <div class="event-content">
                    <div class="event-date">
                        <i class="fas fa-calendar-alt"></i> Every Wednesday
                    </div>
                    <h3>Remote Work Wednesday</h3>
                    <p>Bring your laptop and work from our cozy cafe. Special discounts on coffee and snacks for remote workers all day.</p>
                    <div class="event-time">
                        <i class="fas fa-clock"></i> 8:00 AM - 8:00 PM
                    </div>
                </div>
            </div>
        </div>

        <!-- Event 6 -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="event-card">
                <div class="event-icon">
                    <i class="fas fa-palette"></i>
                </div>
                <div class="event-content">
                    <div class="event-date">
                        <i class="fas fa-calendar-alt"></i> Last Sunday of Month
                    </div>
                    <h3>Art & Coffee Exhibition</h3>
                    <p>Showcase of local artists' work. Enjoy art viewing while enjoying your favorite coffee creations.</p>
                    <div class="event-time">
                        <i class="fas fa-clock"></i> 2:00 PM - 6:00 PM
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="event-cta">
        <h2>Want to Host an Event?</h2>
        <p>Our space is perfect for private events, corporate gatherings, and special celebrations. 
           Contact us to learn more about hosting your event at Istoria Coffee.</p>
        <a asp-controller="Home" asp-action="About" class="btn-elegant">Contact Us</a>
    </div>
</div>

<style>
    /* Event Card Styles */
    .event-card {
        background: var(--bw-white);
        border: 1px solid #eee;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: all 0.4s ease;
    }

    .event-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    .event-icon {
        background: var(--bw-black);
        padding: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .event-icon i {
        font-size: 2.5rem;
        color: var(--bw-white);
    }

    .event-content {
        padding: 2rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .event-date {
        background: var(--bw-gray);
        color: var(--bw-black);
        padding: 0.5rem 1rem;
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
        align-self: flex-start;
    }

    .event-content h3 {
        font-size: 1.4rem;
        margin-bottom: 1rem;
        color: var(--bw-black);
    }

    .event-content p {
        color: var(--bw-medium-gray);
        line-height: 1.7;
        margin-bottom: 1.5rem;
        flex: 1;
        font-size: 0.95rem;
    }

    .event-time {
        color: var(--bw-dark-gray);
        font-size: 0.85rem;
        font-weight: 500;
        padding-top: 1rem;
        border-top: 1px solid #eee;
    }

    .event-time i {
        margin-right: 0.5rem;
    }

    /* Event CTA Section */
    .event-cta {
        background: var(--bw-black);
        padding: 4rem 3rem;
        margin: 4rem 0 2rem;
        text-align: center;
    }

    .event-cta h2 {
        color: var(--bw-white);
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .event-cta p {
        color: rgba(255,255,255,0.7);
        margin-bottom: 2rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.8;
    }

    .event-cta .btn-elegant {
        background: var(--bw-white);
        color: var(--bw-black);
        padding: 1rem 2.5rem;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: inline-block;
        transition: all 0.4s ease;
    }

    .event-cta .btn-elegant:hover {
        background: transparent;
        color: var(--bw-white);
    }

    /* Divider */
    .divider {
        width: 60px;
        height: 1px;
        background: var(--bw-black);
        margin: 1.5rem auto;
    }
</style>
