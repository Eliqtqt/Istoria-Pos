@model IEnumerable<CafeWebsite.Models.Event>
@{
    ViewData["Title"] = "Events";
}

<section class="hero-section" style="background: url('/Images/coffee-bg.jpg') center center / cover no-repeat; background-attachment: fixed;">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="animate-fade-in">Events</h1>
        <p class="lead animate-fade-in animate-delay-1">Join us for special events and activities</p>
    </div>
</section>

<div class="events-section">
    <div class="container">
        @if (ViewBag.Error != null)
        {
            <div class="alert-box" style="background: #dc3545;">Error: @ViewBag.Error</div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert-box">@TempData["Success"]</div>
        }

        @if (!Model.Any())
        {
            <div class="no-events">
                <i class="fas fa-calendar-plus"></i>
                <h3>No Upcoming Events</h3>
                <p>Check back soon for upcoming events at Istoria Coffee!</p>
            </div>
        }
        else
        {
            <div class="events-grid">
                @foreach (var item in Model)
                {
                    <div class="event-card">
                        <div class="event-icon">
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" alt="@item.Title" class="event-image" />
                            }
                            else
                            {
                                <i class="fas @item.Icon"></i>
                            }
                        </div>
                        <div class="event-content">
                            <div class="event-date">
                                <i class="fas fa-calendar-alt"></i> @item.Schedule
                            </div>
                            <h3>@item.Title</h3>
                            <p>@item.Description</p>
                            @if (!string.IsNullOrEmpty(item.Time))
                            {
                                <div class="event-time">
                                    <i class="fas fa-clock"></i> @item.Time
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <div class="event-cta">
            <h2>Want to Host an Event?</h2>
            <p>Our space is perfect for private events, corporate gatherings, and special celebrations. 
               Contact us to learn more about hosting your event at Istoria Coffee.</p>
            <a asp-controller="Home" asp-action="About" class="btn-elegant">Contact Us</a>
        </div>
    </div>
</div>

<style>
    .events-section {
        background: var(--bw-gray);
        padding: 5rem 0;
        min-height: 60vh;
    }

    .alert-box {
        background: var(--bw-black);
        color: var(--bw-white);
        padding: 1rem;
        margin-bottom: 2rem;
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
    }

    .no-events {
        text-align: center;
        padding: 4rem 2rem;
    }

    .no-events i {
        font-size: 4rem;
        color: var(--bw-medium-gray);
        margin-bottom: 1.5rem;
    }

    .no-events h3 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        color: var(--bw-black);
    }

    .no-events p {
        color: var(--bw-medium-gray);
    }

    .events-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .event-card {
        background: var(--bw-white);
        border: none;
        overflow: hidden;
        transition: all 0.4s ease;
    }

    .event-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .event-icon {
        background: var(--bw-black);
        padding: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 180px;
    }

    .event-icon i {
        font-size: 3rem;
        color: var(--bw-white);
    }

    .event-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .event-content {
        padding: 2rem;
    }

    .event-date {
        background: var(--bw-gray);
        color: var(--bw-black);
        padding: 0.5rem 1rem;
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
    }

    .event-content h3 {
        font-size: 1.4rem;
        margin-bottom: 1rem;
        color: var(--bw-black);
    }

    .event-content p {
        color: var(--bw-medium-gray);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .event-time {
        color: var(--bw-dark-gray);
        font-size: 0.85rem;
        font-weight: 500;
        padding-top: 1rem;
        border-top: 1px solid #eee;
    }

    .event-time i {
        margin-right: 0.5rem;
    }

    .event-cta {
        background: var(--bw-black);
        padding: 4rem 3rem;
        margin: 4rem 0 2rem;
        text-align: center;
    }

    .event-cta h2 {
        color: var(--bw-white);
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .event-cta p {
        color: rgba(255,255,255,0.7);
        margin-bottom: 2rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.8;
    }

    .event-cta .btn-elegant {
        background: var(--bw-white);
        color: var(--bw-black);
        padding: 1rem 2.5rem;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: inline-block;
        transition: all 0.4s ease;
    }

    .event-cta .btn-elegant:hover {
        background: transparent;
        color: var(--bw-white);
    }

    .animate-fade-in {
        opacity: 0;
        animation: fadeInUp 0.6s ease forwards;
    }

    .animate-delay-1 { animation-delay: 0.1s; }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 992px) {
        .events-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 576px) {
        .events-grid {
            grid-template-columns: 1fr;
        }
    }
</style>