@{
    ViewData["Title"] = "About";
}

<div class="page-header" style="background: #0a0a0a; color: white;">
    <h1>About Istoria</h1>
    <div class="divider"></div>
    <p style="color: rgba(255,255,255,0.7);">Where every cup tells a story</p>
</div>

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mb-5">
            <h2 style="font-size: 2.5rem; margin-bottom: 1.5rem;">Our Story</h2>
            <p style="color: #666; line-height: 1.8; margin-bottom: 1.5rem;">
                Founded with a passion for exceptional coffee, Istoria Coffee has been serving the community 
                with carefully curated beverages and artisanal treats. We believe in quality ingredients, 
                sustainable practices, and creating memorable moments for every guest.
            </p>
            <p style="color: #666; line-height: 1.8;">
                Our skilled baristas bring craftsmanship to every cup, ensuring precision and care in each brew. 
                From our signature espresso to freshly baked goods, we strive to make your visit unforgettable.
            </p>
        </div>
        <div class="col-lg-6 mb-5">
            <div class="admin-card">
                <h3 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Why Istoria</h3>
                <ul style="list-style: none; padding: 0;">
                    <li style="padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;">
                        <i class="fas fa-mug-hot" style="width: 40px; color: #0a0a0a;"></i>
                        <span><strong>Premium Beans</strong> — Sustainably sourced</span>
                    </li>
                    <li style="padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;">
                        <i class="fas fa-bread-slice" style="width: 40px; color: #0a0a0a;"></i>
                        <span><strong>Fresh Baked</strong> — Made daily</span>
                    </li>
                    <li style="padding: 1rem 0; border-bottom: 1px solid #eee; display: flex; align-items: center;">
                        <i class="fas fa-user-tie" style="width: 40px; color: #0a0a0a;"></i>
                        <span><strong>Expert Baristas</strong> — Passionate craft</span>
                    </li>
                    <li style="padding: 1rem 0; display: flex; align-items: center;">
                        <i class="fas fa-leaf" style="width: 40px; color: #0a0a0a;"></i>
                        <span><strong>Sustainable</strong> — Eco-conscious</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div style="background: #fafafa; padding: 4rem 2rem; margin: 3rem 0; text-align: center;">
        <h2 style="font-size: 2rem; margin-bottom: 2rem;">Visit Us</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <i class="fas fa-map-marker-alt" style="font-size: 1.5rem; color: #0a0a0a; margin-bottom: 1rem;"></i>
                <h5 style="margin-bottom: 0.5rem;">Location</h5>
                <p style="color: #666; margin: 0;">123 Coffee Street<br>Manila, Philippines</p>
            </div>
            <div class="col-md-4 mb-4">
                <i class="fas fa-clock" style="font-size: 1.5rem; color: #0a0a0a; margin-bottom: 1rem;"></i>
                <h5 style="margin-bottom: 0.5rem;">Hours</h5>
                <p style="color: #666; margin: 0;">Mon-Fri: 6AM - 9PM<br>Sat-Sun: 7AM - 10PM</p>
            </div>
            <div class="col-md-4 mb-4">
                <i class="fas fa-phone" style="font-size: 1.5rem; color: #0a0a0a; margin-bottom: 1rem;"></i>
                <h5 style="margin-bottom: 0.5rem;">Contact</h5>
                <p style="color: #666; margin: 0;">+63 912 345 6789<br>hello@istoriacoffee.com</p>
            </div>
        </div>
    </div>
</div>
