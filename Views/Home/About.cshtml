@{
    ViewData["Title"] = "About";
}

<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="animate-fade-in">Istoria <span>Coffee</span></h1>
        <p class="lead animate-fade-in animate-delay-1">Where every cup tells a story</p>
    </div>
</section>

<div class="about-section">
    <div class="container">
        <div class="about-grid">
            <div class="about-content">
                <h2 class="animate-fade-in">Our Story</h2>
                <p class="animate-fade-in animate-delay-1">
                    Founded with a passion for exceptional coffee, Istoria Coffee has been serving the community 
                    with carefully curated beverages and artisanal treats. We believe in quality ingredients, 
                    sustainable practices, and creating memorable moments for every guest.
                </p>
                <p class="animate-fade-in animate-delay-2">
                    Our skilled baristas bring craftsmanship to every cup, ensuring precision and care in each brew. 
                    From our signature espresso to freshly baked goods, we strive to make your visit unforgettable.
                </p>
            </div>
            <div class="about-features">
                <div class="feature-card animate-fade-in">
                    <div class="feature-icon">
                        <i class="fas fa-mug-hot"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Premium Beans</h4>
                        <p>Sustainably sourced</p>
                    </div>
                </div>
                <div class="feature-card animate-fade-in animate-delay-1">
                    <div class="feature-icon">
                        <i class="fas fa-bread-slice"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Fresh Baked</h4>
                        <p>Made daily</p>
                    </div>
                </div>
                <div class="feature-card animate-fade-in animate-delay-2">
                    <div class="feature-icon">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Expert Baristas</h4>
                        <p>Passionate craft</p>
                    </div>
                </div>
                <div class="feature-card animate-fade-in animate-delay-3">
                    <div class="feature-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Sustainable</h4>
                        <p>Eco-conscious</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="visit-section">
    <div class="container">
        <h2 class="animate-fade-in">Visit Us</h2>
        <div class="visit-grid">
            <div class="visit-card animate-fade-in animate-delay-1">
                <i class="fas fa-map-marker-alt"></i>
                <h4>Location</h4>
                <p>Istoria Coffee Shop<br>Brgy. Maitim, Bay, Philippines 4033<br>National Hwy, Manila S Road</p>
            </div>
            <div class="visit-card animate-fade-in animate-delay-2">
                <i class="fas fa-clock"></i>
                <h4>Hours</h4>
                <p>Mon-Fri: 6AM - 9PM<br>Sat-Sun: 7AM - 10PM</p>
            </div>
            <div class="visit-card animate-fade-in animate-delay-3">
                <i class="fas fa-envelope"></i>
                <h4>Email</h4>
                <p><a href="mailto:business.istoria@gmail.com">business.istoria@gmail.com</a></p>
            </div>
            <div class="visit-card animate-fade-in animate-delay-4">
                <i class="fab fa-facebook-messenger"></i>
                <h4>Messenger</h4>
                <p><a href="https://m.me/istoriacoffee" target="_blank">Message Us</a></p>
            </div>
        </div>
    </div>
</div>

<style>
    .about-section {
        background: var(--bw-white);
        padding: 6rem 0;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
    }

    .about-content h2 {
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
        color: var(--bw-black);
    }

    .about-content p {
        color: var(--bw-medium-gray);
        line-height: 1.8;
        margin-bottom: 1.5rem;
    }

    .about-features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .feature-card {
        background: var(--bw-gray);
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .feature-icon {
        width: 50px;
        height: 50px;
        background: var(--bw-black);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .feature-icon i {
        color: var(--bw-white);
        font-size: 1.2rem;
    }

    .feature-text h4 {
        font-size: 1rem;
        margin-bottom: 0.25rem;
        color: var(--bw-black);
    }

    .feature-text p {
        color: var(--bw-medium-gray);
        font-size: 0.85rem;
        margin: 0;
    }

    .visit-section {
        background: var(--bw-black);
        padding: 5rem 0;
        text-align: center;
    }

    .visit-section h2 {
        color: var(--bw-white);
        font-size: 2rem;
        margin-bottom: 3rem;
    }

    .visit-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
    }

    .visit-card {
        padding: 1rem;
    }

    .visit-card i {
        font-size: 1.75rem;
        color: var(--bw-white);
        margin-bottom: 1rem;
        display: block;
    }

    .visit-card h4 {
        color: var(--bw-white);
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.75rem;
    }

    .visit-card p {
        color: rgba(255,255,255,0.7);
        margin: 0;
        line-height: 1.8;
        font-size: 0.9rem;
    }

    .visit-card a {
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .visit-card a:hover {
        color: var(--bw-white);
    }

    .animate-delay-1 { animation-delay: 0.1s; }
    .animate-delay-2 { animation-delay: 0.2s; }
    .animate-delay-3 { animation-delay: 0.3s; }
    .animate-delay-4 { animation-delay: 0.4s; }

    .animate-fade-in {
        opacity: 0;
        animation: fadeInUp 0.6s ease forwards;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 992px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .visit-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 576px) {
        .about-features {
            grid-template-columns: 1fr;
        }

        .visit-grid {
            grid-template-columns: 1fr;
        }
    }
</style>