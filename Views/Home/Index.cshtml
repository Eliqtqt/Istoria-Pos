@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="hero-content">
        <h1 class="animate-fade-in">Istoria <span>Coffee</span></h1>
        <p class="lead animate-fade-in animate-delay-1">Experience meticulously crafted beverages and artisanal pastries in an atmosphere of refined simplicity.</p>
        <a href="@Url.Action("Index", "Menu")" class="btn-elegant animate-fade-in animate-delay-2">Explore Menu</a>
    </div>
    <div class="hero-image">
    </div>
</section>

<section class="py-5" style="background: #fafafa;">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-5">
                <div class="mb-3">
                    <i class="fas fa-mug-hot" style="font-size: 2rem; color: #0a0a0a;"></i>
                </div>
                <h5 style="font-weight: 600; color: #0a0a0a;">Premium Beans</h5>
                <p style="color: #666; font-size: 0.9rem;">Sourced from the world's finest growing regions.</p>
            </div>
            <div class="col-md-4 mb-5">
                <div class="mb-3">
                    <i class="fas fa-bread-slice" style="font-size: 2rem; color: #0a0a0a;"></i>
                </div>
                <h5 style="font-weight: 600; color: #0a0a0a;">Artisan Pastries</h5>
                <p style="color: #666; font-size: 0.9rem;">Freshly baked daily by our skilled bakers.</p>
            </div>
            <div class="col-md-4 mb-5">
                <div class="mb-3">
                    <i class="fas fa-leaf" style="font-size: 2rem; color: #0a0a0a;"></i>
                </div>
                <h5 style="font-weight: 600; color: #0a0a0a;">Sustainable</h5>
                <p style="color: #666; font-size: 0.9rem;">Committed to ethical sourcing practices.</p>
            </div>
        </div>
    </div>
</section>
