@model IEnumerable<CafeWebsite.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
    decimal total = ViewBag.Total;
}

<div class="cart-container">
    <div class="cart-header">
        <h1>Your Order</h1>
        <div class="divider"></div>
        <p class="cart-subtitle">Review your selections</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-cart">
            <div class="empty-cart-icon">
                <i class="fas fa-coffee"></i>
            </div>
            <h3>Your cart is empty</h3>
            <p>Discover our handcrafted beverages and delicious treats</p>
            <a href="@Url.Action("Index", "Menu")" class="btn-elegant">Explore Menu</a>
        </div>
    }
    else
    {
        <div class="cart-content">
            <div class="cart-items">
                <div class="cart-table-wrapper">
                    <table class="cart-table">
                        <thead>
                            <tr>
                                <th style="width: 35%;">Item</th>
                                <th style="width: 20%;">Price</th>
                                <th style="width: 20%;">Quantity</th>
                                <th style="width: 15%;">Total</th>
                                <th style="width: 10%;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="item-info">
                                        <div class="item-name">@item.Name</div>
                                        @if (item.IsCustomizable)
                                        {
                                            <div class="customization-details">
                                                <span class="customization-badge">
                                                    <i class="fas fa-sliders-h"></i> Customized
                                                </span>
                                                <div class="custom-options">
                                                    @if (!string.IsNullOrEmpty(item.Size) && item.Size != "Regular")
                                                    {
                                                        <span class="custom-tag">@item.Size</span>
                                                    }
                                                    @if (item.Sweetness != 100)
                                                    {
                                                        <span class="custom-tag">@item.Sweetness% Sweet</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(item.IceLevel) && item.IceLevel != "Regular")
                                                    {
                                                        <span class="custom-tag">@item.IceLevel</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(item.Toppings))
                                                    {
                                                        <span class="custom-tag">+ @item.Toppings</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(item.SpecialInstructions))
                                                {
                                                    <div class="special-note">
                                                        <i class="fas fa-sticky-note"></i> @item.SpecialInstructions
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div class="price-cell">
                                            <span class="base-price">₱@item.Price.ToString("F2")</span>
                                            @if (item.GetAdditionalPrice() > 0)
                                            {
                                                <span class="add-price">+ ₱@item.GetAdditionalPrice().ToString("F2")</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="quantity-controls">
                                            <form asp-controller="Cart" asp-action="Update" method="post">
                                                <input type="hidden" name="id" value="@item.MenuItemId" />
                                                <input type="hidden" name="size" value="@item.Size" />
                                                <input type="hidden" name="sweetness" value="@item.Sweetness" />
                                                <input type="hidden" name="iceLevel" value="@item.IceLevel" />
                                                <input type="hidden" name="toppings" value="@item.Toppings" />
                                                <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                                <button type="submit" class="qty-btn" @(item.Quantity <= 1 ? "disabled" : "")>
                                                    <i class="fas fa-minus"></i>
                                                </button>
                                            </form>
                                            <span class="qty-value">@item.Quantity</span>
                                            <form asp-controller="Cart" asp-action="Update" method="post">
                                                <input type="hidden" name="id" value="@item.MenuItemId" />
                                                <input type="hidden" name="size" value="@item.Size" />
                                                <input type="hidden" name="sweetness" value="@item.Sweetness" />
                                                <input type="hidden" name="iceLevel" value="@item.IceLevel" />
                                                <input type="hidden" name="toppings" value="@item.Toppings" />
                                                <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                                <button type="submit" class="qty-btn">
                                                    <i class="fas fa-plus"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="item-total">₱@item.GetTotalPrice().ToString("F2")</td>
                                    <td>
                                        <form asp-controller="Cart" asp-action="Remove" method="post">
                                            <input type="hidden" name="id" value="@item.MenuItemId" />
                                            <input type="hidden" name="size" value="@item.Size" />
                                            <input type="hidden" name="sweetness" value="@item.Sweetness" />
                                            <input type="hidden" name="iceLevel" value="@item.IceLevel" />
                                            <input type="hidden" name="toppings" value="@item.Toppings" />
                                            <button type="submit" class="remove-btn" title="Remove item">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="cart-actions">
                    <form asp-controller="Cart" asp-action="Clear" method="post" class="clear-cart">
                        <button type="submit" class="btn-text">
                            <i class="fas fa-trash-alt"></i> Clear Cart
                        </button>
                    </form>
                    <a href="@Url.Action("Index", "Menu")" class="continue-shopping">
                        <i class="fas fa-arrow-left"></i> Add More Items
                    </a>
                </div>
            </div>

            <div class="cart-summary">
                <div class="summary-header">
                    <h3>Order Summary</h3>
                    <div class="summary-icon">
                        <i class="fas fa-receipt"></i>
                    </div>
                </div>
                
                <div class="summary-details">
                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span>₱@total.ToString("F2")</span>
                    </div>
                    <div class="summary-row">
                        <span><i class="fas fa-truck"></i> Delivery</span>
                        <span class="free">Free</span>
                    </div>
                </div>
                
                <div class="summary-total">
                    <span>Total</span>
                    <span>₱@total.ToString("F2")</span>
                </div>

                <div class="checkout-section">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="@Url.Action("Checkout", "Order")" class="btn-checkout">
                            <span>Proceed to Checkout</span>
                            <i class="fas fa-arrow-right"></i>
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")?returnUrl=@Url.Action("Checkout", "Order")" class="btn-checkout">
                            <span>Login to Checkout</span>
                            <i class="fas fa-arrow-right"></i>
                        </a>
                    }
                </div>
                
                <div class="security-note">
                    <i class="fas fa-lock"></i>
                    <span>Secure checkout</span>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .cart-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .cart-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-top: 3rem;
    }

    .cart-header h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .cart-header .divider {
        width: 60px;
        height: 1px;
        background: #0a0a0a;
        margin: 0 auto 1rem;
    }
    
    .cart-subtitle {
        color: #888;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    .empty-cart {
        text-align: center;
        padding: 5rem 2rem;
        background: #fafafa;
    }

    .empty-cart-icon {
        font-size: 4rem;
        color: #ddd;
        margin-bottom: 1.5rem;
    }

    .empty-cart h3 {
        color: #333;
        margin-bottom: 0.5rem;
        font-family: 'Playfair Display', serif;
    }

    .empty-cart p {
        color: #888;
        margin-bottom: 2rem;
    }

    .btn-elegant {
        display: inline-block;
        padding: 1rem 2.5rem;
        background: #0a0a0a;
        color: white;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: all 0.4s ease;
    }

    .btn-elegant:hover {
        background: #333;
        color: white;
    }

    .cart-content {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 2rem;
        align-items: start;
    }

    .cart-table-wrapper {
        background: white;
        border: 1px solid #eee;
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }

    .cart-table thead {
        background: #0a0a0a;
    }

    .cart-table th {
        color: white;
        padding: 1.2rem 1rem;
        font-weight: 500;
        font-size: 0.75rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        text-align: left;
    }

    .cart-table td {
        padding: 1.2rem 1rem;
        border-bottom: 1px solid #eee;
        vertical-align: middle;
    }

    .item-name {
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 5px;
    }

    .customization-details {
        margin-top: 8px;
    }

    .customization-badge {
        display: inline-block;
        background: #0a0a0a;
        color: white;
        padding: 3px 10px;
        font-size: 0.65rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .customization-badge i {
        margin-right: 5px;
    }

    .custom-options {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
    }

    .custom-tag {
        display: inline-block;
        background: #f5f5f5;
        color: #555;
        padding: 3px 8px;
        font-size: 0.7rem;
    }

    .special-note {
        margin-top: 8px;
        color: #856404;
        background: #fff8e1;
        padding: 8px 10px;
        font-size: 0.8rem;
    }

    .special-note i {
        margin-right: 5px;
    }

    .price-cell {
        display: flex;
        flex-direction: column;
    }

    .base-price {
        font-weight: 500;
    }

    .add-price {
        color: #28a745;
        font-size: 0.8rem;
    }

    .quantity-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .qty-btn {
        width: 32px;
        height: 32px;
        border: 1px solid #ddd;
        background: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        font-size: 0.7rem;
    }

    .qty-btn:hover:not(:disabled) {
        background: #0a0a0a;
        color: white;
        border-color: #0a0a0a;
    }

    .qty-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .qty-value {
        min-width: 35px;
        text-align: center;
        font-weight: 600;
        font-size: 1rem;
    }

    .item-total {
        font-weight: 700;
        font-size: 1.1rem;
        color: #0a0a0a;
    }

    .remove-btn {
        background: none;
        border: none;
        color: #ccc;
        cursor: pointer;
        padding: 8px;
        transition: color 0.2s;
        font-size: 1rem;
    }

    .remove-btn:hover {
        color: #dc3545;
    }

    .cart-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.5rem;
        padding: 0 0.5rem;
    }

    .btn-text {
        background: none;
        border: none;
        color: #888;
        cursor: pointer;
        font-size: 0.85rem;
        transition: color 0.2s;
    }

    .btn-text:hover {
        color: #0a0a0a;
    }

    .btn-text i {
        margin-right: 5px;
    }

    .continue-shopping {
        color: #0a0a0a;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: opacity 0.2s;
    }

    .continue-shopping:hover {
        opacity: 0.7;
    }

    .continue-shopping i {
        margin-right: 5px;
    }

    /* Summary Card */
    .cart-summary {
        background: white;
        border: 1px solid #eee;
        position: sticky;
        top: 100px;
    }

    .summary-header {
        background: #0a0a0a;
        color: white;
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .summary-header h3 {
        margin: 0;
        font-size: 1.1rem;
        letter-spacing: 1px;
    }

    .summary-icon {
        font-size: 1.2rem;
        opacity: 0.7;
    }

    .summary-details {
        padding: 1.5rem;
        border-bottom: 1px solid #eee;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 0.8rem 0;
        color: #555;
        font-size: 0.9rem;
    }

    .summary-row .free {
        color: #28a745;
        font-weight: 500;
    }

    .summary-row i {
        margin-right: 8px;
        color: #888;
    }

    .summary-total {
        display: flex;
        justify-content: space-between;
        padding: 1.5rem;
        font-size: 1.4rem;
        font-weight: 700;
        color: #0a0a0a;
        font-family: 'Playfair Display', serif;
    }

    .checkout-section {
        padding: 0 1.5rem 1.5rem;
    }

    .btn-checkout {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        padding: 1.2rem 1.5rem;
        background: #0a0a0a;
        color: white;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: all 0.3s ease;
        border-bottom-left-radius: 8px;
        border-bottom-right-radius: 8px;
    }

    .btn-checkout:hover {
        background: #333;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .security-note {
        text-align: center;
        padding: 1rem;
        color: #888;
        font-size: 0.8rem;
        border-top: 1px solid #eee;
    }

    .security-note i {
        margin-right: 5px;
    }

    @@media (max-width: 992px) {
        .cart-content {
            grid-template-columns: 1fr;
        }
        
        .cart-summary {
            position: static;
        }
    }
    
    @@media (max-width: 768px) {
        .cart-header h1 {
            font-size: 2rem;
        }
        
        .cart-table th:nth-child(2),
        .cart-table td:nth-child(2),
        .cart-table th:nth-child(3),
        .cart-table td:nth-child(3) {
            display: none;
        }
    }
</style>
