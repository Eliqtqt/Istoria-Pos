@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <!-- Header -->
            <div class="auth-header">
                <h1>Welcome Back</h1>
                <p class="subtitle">Sign in to continue to your account</p>
            </div>

            <!-- Success Message -->
            @if (TempData["Success"] != null)
            {
                <div class="alert-message success">
                    <i class="fas fa-check-circle"></i>
                    @TempData["Success"]
                </div>
            }

            <!-- Error Messages -->
            @if (TempData["Error"] != null)
            {
                <div class="alert-message error">
                    <i class="fas fa-exclamation-circle"></i>
                    @TempData["Error"]
                </div>
            }
            
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert-message error">
                    <i class="fas fa-exclamation-circle"></i>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                </div>
            }

            <!-- Login Form -->
            <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                
                <div class="form-group">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="username" name="username" 
                           placeholder="Enter your username" value="@(TempData["Username"] ?? "")" required />
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password" 
                           placeholder="Enter your password" required />
                </div>

                <div class="form-options">
                    <label class="checkbox-label">
                        <input type="checkbox" class="checkbox-input" name="rememberMe" />
                        <span class="checkbox-custom"></span>
                        Remember me
                    </label>
                    <a href="#" class="link-text">Forgot password?</a>
                </div>
                
                <button type="submit" class="btn-submit">
                    Sign In
                </button>
            </form>

            <!-- Register Link -->
            <div class="auth-footer">
                <p>Don't have an account? <a asp-action="Register">Create one</a></p>
            </div>

            <style>
    .auth-page {
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 10rem 1rem 4rem;
        background: linear-gradient(180deg, #f8f8f8 0%, #eeeeee 100%);
    }

    .auth-container {
        width: 100%;
        max-width: 420px;
    }

    .auth-card {
        background: #ffffff;
        border: 1px solid #d0d0d0;
        border-radius: 0;
        padding: 3rem 2.5rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #eeeeee;
    }

    .auth-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.8rem;
        color: #0a0a0a;
        margin-bottom: 0.5rem;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .subtitle {
        color: #808080;
        font-size: 0.9rem;
        margin: 0;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .alert-message {
        padding: 0.875rem 1rem;
        border-radius: 4px;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .alert-message.success {
        background: #f0f9f0;
        color: #2d5a27;
        border: 1px solid #c3e6c3;
    }

    .alert-message.error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .alert-message i {
        margin-top: 2px;
        font-size: 1rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        font-weight: 500;
        color: #0a0a0a;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        letter-spacing: 0.5px;
    }

    .form-control {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 1px solid #cccccc;
        border-radius: 4px;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        background: #fafafa;
        color: #0a0a0a;
    }

    .form-control:focus {
        outline: none;
        border-color: #000;
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
        background: #ffffff;
    }

    .form-control::placeholder {
        color: #999999;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        color: #808080;
        user-select: none;
    }

    .checkbox-input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .checkbox-custom {
        width: 18px;
        height: 18px;
        border: 1px solid #999999;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .checkbox-input:checked + .checkbox-custom {
        background: #000;
        border-color: #000;
    }

    .checkbox-input:checked + .checkbox-custom::after {
        content: '✓';
        color: white;
        font-size: 11px;
    }

    .link-text {
        color: #000;
        text-decoration: none;
        font-weight: 500;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
    }

    .link-text:hover {
        border-bottom-color: #000;
    }

    .btn-submit {
        width: 100%;
        padding: 1rem 1.5rem;
        background: #000;
        color: white;
        border: 1px solid #000;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .btn-submit:hover {
        background: #333;
        border-color: #333;
    }

    .btn-submit:active {
        background: #000;
        border-color: #000;
    }

    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #eeeeee;
        color: #808080;
        font-size: 0.85rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .auth-footer a {
        color: #000;
        font-weight: 600;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: all 0.2s;
    }

    .auth-footer a:hover {
        text-decoration: none;
        border-bottom-color: #000;
    }

    @@media (max-width: 480px) {
        .auth-card {
            padding: 2rem 1.5rem;
        }
    }
</style>
