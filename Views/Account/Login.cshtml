@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <!-- Header -->
            <div class="auth-header">
                <h1>Welcome Back</h1>
                <p class="subtitle">Sign in to continue to your account</p>
            </div>

            <!-- Success Message -->
            @if (TempData["Success"] != null)
            {
                <div class="alert-message success">
                    <i class="fas fa-check-circle"></i>
                    @TempData["Success"]
                </div>
            }

            <!-- Error Messages -->
            @if (TempData["Error"] != null)
            {
                <div class="alert-message error">
                    <i class="fas fa-exclamation-circle"></i>
                    @TempData["Error"]
                </div>
            }
            
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert-message error">
                    <i class="fas fa-exclamation-circle"></i>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                </div>
            }

            <!-- Login Form -->
            <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                
                <div class="form-group">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="username" name="username" 
                           placeholder="Enter your username" value="@(TempData["Username"] ?? "")" required />
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password" 
                           placeholder="Enter your password" required />
                </div>

                <div class="form-options">
                    <label class="checkbox-label">
                        <input type="checkbox" class="checkbox-input" name="rememberMe" />
                        <span class="checkbox-custom"></span>
                        Remember me
                    </label>
                    <a href="#" class="link-text">Forgot password?</a>
                </div>
                
                <button type="submit" class="btn-submit">
                    Sign In
                </button>
            </form>

            <!-- Resend Verification & Register Link -->
            <div class="auth-footer">
                <p>Don't have an account? <a asp-action="Register">Create one</a></p>
                <p class="resend-link">
                    <a href="#" onclick="resendConfirmation(event)">Resend confirmation email</a>
                </p>
            </div>

            <!-- Resend Confirmation Modal -->
            <div id="resendModal" class="modal-overlay" style="display:none;">
                <div class="modal-content">
                    <h3>Resend Email Confirmation</h3>
                    <p>Enter your email address to receive a new confirmation link.</p>
                    <input type="email" id="resendEmail" class="form-control" placeholder="Enter your email" />
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeResendModal()">Cancel</button>
                        <button type="button" class="btn-submit" onclick="submitResend()">Send</button>
                    </div>
                </div>
            </div>

            <script>
                function resendConfirmation(e) {
                    e.preventDefault();
                    document.getElementById('resendModal').style.display = 'flex';
                }

                function closeResendModal() {
                    document.getElementById('resendModal').style.display = 'none';
                }

                async function submitResend() {
                    const email = document.getElementById('resendEmail').value;
                    if (!email) {
                        alert('Please enter your email address');
                        return;
                    }

                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '@Url.Action("ResendConfirmation", "Account")';
                    
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'email';
                    input.value = email;
                    form.appendChild(input);
                    
                    document.body.appendChild(form);
                    form.submit();
                }

                // Close modal on outside click
                document.getElementById('resendModal')?.addEventListener('click', function(e) {
                    if (e.target === this) closeResendModal();
                });
            </script>
        </div>
    </div>
</div>

<style>
    .auth-page {
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 10rem 1rem 4rem;
        background: linear-gradient(180deg, #f8f8f8 0%, #eeeeee 100%);
    }

    .auth-container {
        width: 100%;
        max-width: 420px;
    }

    .auth-card {
        background: #ffffff;
        border: 1px solid #d0d0d0;
        border-radius: 0;
        padding: 3rem 2.5rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e0e0e0;
    }

    .auth-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.8rem;
        color: #0a0a0a;
        margin-bottom: 0.5rem;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .subtitle {
        color: #808080;
        font-size: 0.9rem;
        margin: 0;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .alert-message {
        padding: 0.875rem 1rem;
        border-radius: 4px;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .alert-message.success {
        background: #f0f9f0;
        color: #2d5a27;
        border: 1px solid #c3e6c3;
    }

    .alert-message.error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .alert-message i {
        margin-top: 2px;
        font-size: 1rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        font-weight: 500;
        color: #0a0a0a;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        letter-spacing: 0.5px;
    }

    .form-control {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 1px solid #cccccc;
        border-radius: 4px;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        background: #fafafa;
        color: #0a0a0a;
    }

    .form-control:focus {
        outline: none;
        border-color: #8B4513;
        box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
        background: #ffffff;
    }

    .form-control::placeholder {
        color: #999999;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        color: #808080;
        user-select: none;
    }

    .checkbox-input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .checkbox-custom {
        width: 18px;
        height: 18px;
        border: 1px solid #999999;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .checkbox-input:checked + .checkbox-custom {
        background: #8B4513;
        border-color: #8B4513;
    }

    .checkbox-input:checked + .checkbox-custom::after {
        content: '✓';
        color: white;
        font-size: 11px;
    }

    .link-text {
        color: #8B4513;
        text-decoration: none;
        font-weight: 500;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
    }

    .link-text:hover {
        border-bottom-color: #8B4513;
    }

    .btn-submit {
        width: 100%;
        padding: 1rem 1.5rem;
        background: #8B4513;
        color: white;
        border: 1px solid #8B4513;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .btn-submit:hover {
        background: #A0522D;
        border-color: #A0522D;
    }

    .btn-submit:active {
        background: #8B4513;
        border-color: #8B4513;
    }

    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e0e0e0;
        color: #808080;
        font-size: 0.85rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .auth-footer a {
        color: #8B4513;
        font-weight: 600;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: all 0.2s;
    }

    .auth-footer a:hover {
        text-decoration: none;
        border-bottom-color: #8B4513;
    }

    .resend-link {
        margin-top: 1rem;
        font-size: 0.8rem;
    }

    .resend-link a {
        color: #8B4513;
        text-decoration: none;
        font-weight: 500;
    }

    .resend-link a:hover {
        text-decoration: underline;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .modal-content {
        background: #ffffff;
        padding: 2rem;
        border-radius: 8px;
        max-width: 400px;
        width: 90%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .modal-content h3 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.3rem;
        margin-bottom: 0.75rem;
        color: #0a0a0a;
    }

    .modal-content p {
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 1.25rem;
    }

    .modal-content .form-control {
        margin-bottom: 1.25rem;
    }

    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .btn-cancel {
        padding: 0.6rem 1.2rem;
        background: #f0f0f0;
        color: #333;
        border: 1px solid #ddd;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.85rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .btn-cancel:hover {
        background: #e0e0e0;
    }

    @@media (max-width: 480px) {
        .auth-card {
            padding: 2rem 1.5rem;
        }
    }
</style>
