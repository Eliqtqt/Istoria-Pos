@model CafeWebsite.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="confirmation-container">
    <div class="confirmation-content">
        <div class="success-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        
        <h1>Thank You!</h1>
        <p class="order-number">Order #@Model.Id</p>
        
        <div class="divider"></div>
        
        <div class="order-details">
            <div class="detail-row">
                <span>Order Date</span>
                <span>@Model.OrderDate.ToString("MMMM dd, yyyy - h:mm tt")</span>
            </div>
            <div class="detail-row">
                <span>Status</span>
                <span class="status-badge">@Model.Status</span>
            </div>
            <div class="detail-row">
                <span>Payment Method</span>
                <span>@Model.PaymentMethod</span>
            </div>
            <div class="detail-row">
                <span>Payment Status</span>
                <span class="status-badge paid">@Model.PaymentStatus</span>
            </div>
        </div>

        <div class="order-items">
            <h3>Order Items</h3>
            <table class="items-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>@item.MenuItem?.Name</td>
                            <td>@item.Quantity</td>
                            <td>₱@item.Price.ToString("F2")</td>
                            <td>₱@((item.Price * item.Quantity).ToString("F2"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3"><strong>Total</strong></td>
                        <td><strong>₱@Model.TotalAmount.ToString("F2")</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="confirmation-message">
            <p>Your order has been placed successfully! We'll notify you when it's ready.</p>
        </div>

        <div class="confirmation-actions">
            <a href="@Url.Action("MyOrders", "Order")" class="btn-primary">View My Orders</a>
            <a href="@Url.Action("Index", "Menu")" class="btn-secondary">Continue Shopping</a>
        </div>
    </div>
</div>

<style>
    .confirmation-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
    }

    .confirmation-content {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 4rem;
        text-align: center;
    }

    .success-icon {
        margin-bottom: 2rem;
    }

    .success-icon i {
        font-size: 5rem;
        color: #28a745;
    }

    .confirmation-content h1 {
        font-family: 'Playfair Display', serif;
        color: #1a1a1a;
        margin-bottom: 0.75rem;
        font-size: 2.5rem;
    }

    .order-number {
        font-size: 1.5rem;
        color: #666;
        margin-bottom: 2rem;
    }

    .divider {
        width: 60px;
        height: 2px;
        background: #0a0a0a;
        margin: 0 auto 2rem;
    }

    .order-details {
        background: #f8f8f8;
        padding: 2rem;
        border-radius: 12px;
        margin: 2rem 0;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 0.85rem 0;
        border-bottom: 1px solid #eee;
    }

    .detail-row:last-child {
        border-bottom: none;
    }

    .status-badge {
        display: inline-block;
        padding: 0.4rem 1rem;
        background: #ffc107;
        color: #333;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .order-items {
        margin: 2.5rem 0;
        text-align: left;
    }

    .order-items h3 {
        margin-bottom: 1.25rem;
        color: #1a1a1a;
    }

    .items-table th {
        text-align: left;
        padding: 1rem;
        border-bottom: 2px solid #1a1a1a;
        color: #333;
        font-weight: 600;
    }

    .items-table td {
        padding: 1rem;
        border-bottom: 1px solid #eee;
    }

    .confirmation-message {
        color: #666;
        margin: 2rem 0;
        font-size: 1rem;
    }

    .confirmation-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2.5rem;
    }

    .btn-primary {
        display: inline-block;
        padding: 1rem 2.5rem;
        background: #1a1a1a;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        transition: background 0.2s;
        font-weight: 600;
    }

    .btn-secondary {
        display: inline-block;
        padding: 1rem 2.5rem;
        background: white;
        color: #1a1a1a;
        text-decoration: none;
        border: 1px solid #1a1a1a;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .status-badge.paid {
        background: #28a745;
        color: white;
    }

    .order-items {
        margin: 2rem 0;
        text-align: left;
    }

    .order-items h3 {
        margin-bottom: 1rem;
        color: #1a1a1a;
    }

    .items-table {
        width: 100%;
        border-collapse: collapse;
    }

    .items-table th {
        text-align: left;
        padding: 0.75rem;
        border-bottom: 2px solid #1a1a1a;
        color: #333;
    }

    .items-table td {
        padding: 0.75rem;
        border-bottom: 1px solid #eee;
    }

    .items-table tfoot td {
        border-top: 2px solid #1a1a1a;
        padding-top: 1rem;
    }

    .confirmation-message {
        color: #666;
        margin: 1.5rem 0;
    }

    .confirmation-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2rem;
    }

    .btn-primary {
        display: inline-block;
        padding: 0.75rem 2rem;
        background: #1a1a1a;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        transition: background 0.2s;
    }

    .btn-primary:hover {
        background: #333;
        color: white;
    }

    .btn-secondary {
        display: inline-block;
        padding: 0.75rem 2rem;
        background: white;
        color: #1a1a1a;
        text-decoration: none;
        border: 1px solid #1a1a1a;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        background: #1a1a1a;
        color: white;
    }
</style>
