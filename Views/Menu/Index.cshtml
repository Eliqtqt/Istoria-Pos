}

.hero-subtitle {
    color: rgba(255,255,255,0.9);
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto 0.5rem;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    letter-spacing: 1px;
}

.hero-tagline {
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
    max-width: 500px;
    margin: 0 auto;
    font-style: italic;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
}

/* Menu Container */
.menu-container {
    background: #f7f4ef;
    padding: 4rem 2rem;
    min-height: 100vh;
    position: relative;
}

/* Add subtle pattern or texture for café feel */
.menu-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,%3Csvg width=%2220%22 height=%2220%22 viewBox=%220 0 20 20%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22%239C9C9C%22 fill-opacity=%220.05%22 fill-rule=%22evenodd%22%3E%3Ccircle cx=%220%22 cy=%220%22 r=%221%22/%3E%3C/g%3E%3C/svg%3E');
}

/* Category Tabs - Enhanced for Café */
.category-tabs {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem 2rem;
    background: #fff;
    border-bottom: 1px solid #e5e0d8;
    margin-bottom: 3rem;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    overflow-x: auto;
    flex-wrap: wrap;
}

.tab-btn {
    background: transparent;
    border: 2px solid transparent;
    color: #666;
    padding: 0.75rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    white-space: nowrap;
    border-radius: 50px;
}

.tab-btn::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: #0a0a0a;
    transition: width 0.3s ease;
}

.tab-btn:hover {
    color: #333;
    background: rgba(0,0,0,0.02);
}

.tab-btn.active {
    color: #0a0a0a;
    font-weight: 600;
    border-color: #0a0a0a;
}

.tab-btn.active::after {
    width: 60%;
}

/* Menu Grid */
.menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
    max-width: 1200px;
    margin: 0 auto;
}

/* Menu Card - Enhanced for Café */
.menu-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: all 0.4s ease;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.03);
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
}

.menu-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.12);
    border-color: rgba(0,0,0,0.08);
}

/* Add subtle hover effect to card */
.menu-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, #0a0a0a, transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.menu-card:hover::before {
    opacity: 0.3;
}

/* Card Image - Enhanced for Café */
.card-image {
    position: relative;
    aspect-ratio: 1/1;
    background: #f7f4ef;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    transition: transform 0.5s ease, filter 0.3s ease;
    filter: brightness(0.98) contrast(1.02);
}

.menu-card:hover .card-image img {
    transform: scale(1.05);
    filter: brightness(1) contrast(1.05);
}

/* Add subtle overlay effect on hover */
.card-image::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.03));
    opacity: 0;
    transition: opacity 0.3s ease;
}

.menu-card:hover .card-image::after {
    opacity: 0.5;
}

.image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f7f4ef;
}

.image-placeholder span {
    color: #999;
    font-size: 0.9rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 500;
}

.category-badge {
