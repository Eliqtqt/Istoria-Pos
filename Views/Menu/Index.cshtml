/* Product Info - Always Visible */
.product-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, transparent 0%, rgba(0,0,0,0.6) 30%, rgba(0,0,0,0.8) 100%);
