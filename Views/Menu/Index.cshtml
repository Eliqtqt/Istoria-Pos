@model IEnumerable<CafeWebsite.Models.MenuItem>

@{
    ViewData["Title"] = "Menu";
}

<!-- Hero Section -->
<div class="hero-section">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="~/Videos/istoriajo.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="hero-title">ISTORIA</h1>
        <p class="hero-subtitle">[is-tor-yuh] • noun</p>
        <p class="hero-tagline">a place of laughter, comfort and acceptance; where memories are made over a cup of coffee and friends.</p>
    </div>
</div>

<!-- Menu Container -->
<div class="menu-container">
    <!-- Category Tabs -->
    <div class="category-tabs">
        <button class="tab-btn active" data-category="all">All</button>
        <button class="tab-btn" data-category="coffee">Coffee</button>
        <button class="tab-btn" data-category="non-coffee">Non-Coffee</button>
        <button class="tab-btn" data-category="specials">Specials</button>
        <button class="tab-btn" data-category="latte">Latte</button>
        <button class="tab-btn" data-category="pasta">Pasta</button>
        <button class="tab-btn" data-category="pastry">Pastry</button>
        <button class="tab-btn" data-category="potato">Potato</button>
        <button class="tab-btn" data-category="chicken poppers">Chicken Poppers</button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-box">
            @TempData["Success"]
        </div>
    }

    <!-- Menu Grid -->
    <div class="menu-grid">
        @foreach (var item in Model)
        {
            var isDrink = item.Category.ToLower() == "coffee" || item.Category.ToLower() == "non-coffee" || 
                          item.Category.ToLower() == "specials" || item.Category.ToLower() == "latte" ||
                          item.Category.ToLower() == "tea" || item.Category.ToLower() == "frappe" || 
                          item.Category.ToLower() == "milk tea";
            
            <div class="menu-card" data-category="@item.Category.ToLower()">
                <!-- Card Image -->
                <div class="card-image">
                    @if (!string.IsNullOrEmpty(item.ImageUrl) && item.ImageUrl.StartsWith("http"))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                        <div class="image-placeholder" style="display:none;">
                            <span>Image</span>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                        <div class="image-placeholder" style="display:none;">
                            <span>Image</span>
                        </div>
                    }
                    else
                    {
                        <div class="image-placeholder">
                            <span>No Image</span>
                        </div>
                    }
                    <span class="category-badge">@item.Category</span>
                </div>
                
                <!-- Card Content -->
                <div class="card-content">
                    <h3 class="product-name">@item.Name</h3>
                    <p class="product-description">@item.Description</p>
                    
                    @if (item.Rating > 0)
                    {
                        <div class="rating-wrapper">
                            <div class="stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star" style="color: @(i <= item.Rating ? "#0a0a0a" : "#ddd")"></i>
                                }
                            </div>
                            <span class="rating-value">@item.Rating.ToString("F1")</span>
                        </div>
                    }

                    <div class="card-footer">
                        <span class="price">&#8369;@item.Price.ToString("F2")</span>
                        <div class="card-buttons">
                            @if (isDrink)
                            {
                                <button type="button" class="btn-customize" onclick="openCustomizeModal(@item.Id, &quot;@item.Name&quot;, @item.Price, true)">
                                    Customize
                                </button>
                            }
                            else
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="name" value="@item.Name" />
                                    <input type="hidden" name="price" value="@item.Price" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn-add">
                                        <i class="fas fa-plus"></i> Add
                                    </button>
                                </form>
                            }
                            <a href="@Url.Action("Details", "Menu", new { id = item.Id })" class="btn-view">
                                View
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Customization Modal -->
<div class="modal fade" id="customizeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-coffee"></i> Craft Your Perfect Drink</h5>
                <button type="button" class="close" onclick="$('#customizeModal').modal('hide')">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="customizationForm">
                    <input type="hidden" id="menuItemId" />
                    <input type="hidden" id="menuItemName" />
                    <input type="hidden" id="menuItemPrice" />
                    
                    <div class="customize-header">
                        <h4 id="modalItemName"></h4>
                        <p>Base Price: &#8369;<span id="modalBasePrice"></span></p>
                    </div>
                    
                    <div class="option-group">
                        <label>Size</label>
                        <div class="option-options">
                            <label><input type="radio" name="size" value="Regular" checked> Regular</label>
                            <label><input type="radio" name="size" value="Large"> Large +&#8369;20</label>
                            <label><input type="radio" name="size" value="Extra Large"> XL +&#8369;35</label>
                        </div>
                    </div>
                    
                    <div class="option-group">
                        <label>Sweetness</label>
                        <input type="range" id="menuSweetness" min="0" max="100" value="100" step="25">
                        <div class="sweetness-display"><span id="sweetnessText">100%</span></div>
                    </div>
                    
                    <div class="option-group">
                        <label>Ice Level</label>
                        <div class="option-options">
                            <label><input type="radio" name="iceLevel" value="Regular" checked> Regular</label>
                            <label><input type="radio" name="iceLevel" value="Less Ice"> Less Ice</label>
                            <label><input type="radio" name="iceLevel" value="No Ice"> No Ice</label>
                            <label><input type="radio" name="iceLevel" value="Extra Ice"> Extra Ice</label>
                        </div>
                    </div>
                    
                    <div class="option-group">
                        <label>Toppings (+&#8369;15 each)</label>
                        <div class="option-options">
                            <label><input type="checkbox" name="toppings" value="Pearl"> Pearl</label>
                            <label><input type="checkbox" name="toppings" value="Coconut"> Coconut</label>
                            <label><input type="checkbox" name="toppings" value="Grass Jelly"> Grass Jelly</label>
                            <label><input type="checkbox" name="toppings" value="Pudding"> Pudding</label>
                            <label><input type="checkbox" name="toppings" value="Nata"> Nata</label>
                            <label><input type="checkbox" name="toppings" value="Cheese Foam"> Cheese Foam</label>
                        </div>
                    </div>
                    
                    <div class="option-group">
                        <label>Special Instructions</label>
                        <textarea id="menuInstructions" placeholder="Any special requests..."></textarea>
                    </div>
                    
                    <div class="option-group">
                        <label>Quantity</label>
                        <div class="qty-controls">
                            <button type="button" onclick="menuDecreaseQty()">-</button>
                            <input type="number" id="menuQty" value="1" min="1">
                            <button type="button" onclick="menuIncreaseQty()">+</button>
                        </div>
                    </div>
                    
                    <div class="total-display">
                        Total: &#8369;<span id="menuTotal"></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="$('#customizeModal').modal('hide')">Cancel</button>
                <button type="button" onclick="addMenuToCart()">
                    <i class="fas fa-shopping-cart"></i> Add to Cart
                </button>
            </div>
        </div>
    </div>
</div>

<style>
/* Hero Section */
.hero-section {
    position: relative;
    height: 55vh;
    min-height: 450px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.35);
}

.hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
}

.hero-title {
    font-size: 3.5rem;
    color: #fff;
    letter-spacing: 8px;
    margin-bottom: 0.75rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
}

.hero-subtitle {
    color: rgba(255,255,255,0.9);
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto 0.5rem;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    letter-spacing: 1px;
}

.hero-tagline {
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
    max-width: 500px;
    margin: 0 auto;
    font-style: italic;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
}

/* Menu Container */
.menu-container {
    background: #f7f4ef;
    padding: 3rem 2rem 4rem;
    min-height: 100vh;
}

/* Category Tabs */
.category-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem 2rem;
    background: #fff;
    border-bottom: 2px solid #e5e0d8;
    margin-bottom: 2.5rem;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
}

.tab-btn {
    background: transparent;
    border: none;
    color: #666;
    padding: 0.6rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
}

.tab-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: #0a0a0a;
    transition: width 0.3s ease;
}

.tab-btn:hover {
    color: #333;
}

.tab-btn.active {
    color: #0a0a0a;
    font-weight: 600;
}

.tab-btn.active::after {
    width: 60%;
}

/* Menu Grid */
.menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
    max-width: 1200px;
    margin: 0 auto;
}

/* Menu Card */
.menu-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    overflow: hidden;
}

.menu-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.12);
}

/* Card Image */
.card-image {
    position: relative;
    height: 180px;
    background: #e5e0d8;
    overflow: hidden;
}

.card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.menu-card:hover .card-image img {
    transform: scale(1.1);
}

.image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e5e0d8;
}

.image-placeholder span {
    color: #999;
    font-size: 0.9rem;
    letter-spacing: 2px;
    text-transform: uppercase;
}

.category-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #0a0a0a;
    color: #fff;
    padding: 0.3rem 0.75rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* Card Content */
.card-content {
    padding: 1.25rem;
}

.product-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.5rem;
}

.product-description {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.5;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Rating */
.rating-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
}

.stars {
    display: flex;
    gap: 2px;
}

.stars i {
    font-size: 0.7rem;
}

.rating-value {
    font-size: 0.8rem;
    color: #666;
}

/* Card Footer */
.card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid #eee;
    margin-top: 0.5rem;
}

.price {
    font-size: 1.2rem;
    font-weight: 700;
    color: #0a0a0a;
}

.card-buttons {
    display: flex;
    gap: 0.5rem;
}

/* Buttons */
.btn-customize {
    background: transparent;
    color: #0a0a0a;
    border: 1px solid #0a0a0a;
    padding: 0.5rem 0.85rem;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-customize:hover {
    background: #0a0a0a;
    color: #fff;
}

.btn-add {
    background: transparent;
    color: #0a0a0a;
    border: 1px solid #0a0a0a;
    padding: 0.5rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
}

.btn-add:hover {
    background: #0a0a0a;
    color: #fff;
}

.btn-view {
    background: #0a0a0a;
    color: #fff;
    border: 1px solid #0a0a0a;
    padding: 0.5rem 0.85rem;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
}

.btn-view:hover {
    background: #333;
    border-color: #333;
}

/* Alert */
.alert-box {
    background: #0a0a0a;
    color: #fff;
    padding: 1rem;
    margin-bottom: 2rem;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
}

/* Modal */
.modal-content {
    background: #fff;
    border: none;
}

.modal-header {
    background: #0a0a0a;
    color: #fff;
    border: none;
}

.modal-header .close {
    color: #fff;
}

.modal-body {
    padding: 1.5rem;
}

.customize-header {
    background: #f7f4ef;
    padding: 1rem;
    margin-bottom: 1.25rem;
}

.customize-header h4 {
    color: #0a0a0a;
    margin-bottom: 0.25rem;
}

.customize-header p {
    color: #666;
    font-size: 0.9rem;
}

.option-group {
    margin-bottom: 1rem;
}

.option-group label {
    display: block;
    color: #0a0a0a;
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.option-options {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
}

.option-options label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #0a0a0a;
    font-weight: 400;
    cursor: pointer;
}

.option-group input[type="range"] {
    width: 100%;
}

.sweetness-display {
    text-align: center;
    margin-top: 0.25rem;
}

.option-group textarea {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid #ddd;
    min-height: 80px;
}

.qty-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.qty-controls button {
    width: 35px;
    height: 35px;
    background: #0a0a0a;
    color: #fff;
    border: 1px solid #0a0a0a;
    cursor: pointer;
}

.qty-controls input {
    width: 50px;
    padding: 0.5rem;
    border: 1px solid #ddd;
    text-align: center;
}

.total-display {
    background: #0a0a0a;
    padding: 1rem;
    text-align: center;
    color: #fff;
    font-size: 1.2rem;
}

.total-display span {
    font-weight: 700;
}

.modal-footer {
    background: #f7f4ef;
    border: none;
    display: flex;
    justify-content: space-between;
}

.modal-footer button {
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    font-weight: 500;
}

.modal-footer button:first-child {
    background: #fff;
    color: #0a0a0a;
    border: 1px solid #0a0a0a;
}

.modal-footer button:last-child {
    background: #0a0a0a;
    color: #fff;
    border: 1px solid #0a0a0a;
}

/* Responsive */
@@media (max-width: 768px) {
    .hero-title {
        font-size: 2.5rem;
        letter-spacing: 4px;
    }
    
    .menu-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
    }
    
    .menu-container {
        padding: 2rem 1rem 3rem;
    }
    
    .category-tabs {
        padding: 1rem;
    }
}
</style>

<script>
var menuBasePrice = 0;

function openCustomizeModal(id, name, price, isCustomizable) {
    if (!isCustomizable) return;
    id = parseInt(id);
    price = parseFloat(price);
    $('#menuItemId').val(id);
    $('#menuItemName').val(name);
    $('#menuItemPrice').val(price);
    $('#modalItemName').text(name);
    $('#modalBasePrice').text(price.toFixed(2));
    menuBasePrice = price;
    $('input[name="size"][value="Regular"]').prop('checked', true);
    $('#menuSweetness').val(100);
    $('#sweetnessText').text('100%');
    $('input[name="iceLevel"][value="Regular"]').prop('checked', true);
    $('input[name="toppings"]').prop('checked', false);
    $('#menuInstructions').val('');
    $('#menuQty').val(1);
    updateMenuTotal();
    $('#customizeModal').modal('show');
}

function menuIncreaseQty() { 
    $('#menuQty').val(parseInt($('#menuQty').val()) + 1); 
    updateMenuTotal(); 
}

function menuDecreaseQty() { 
    var q = parseInt($('#menuQty').val()); 
    if(q > 1) $('#menuQty').val(q - 1); 
    updateMenuTotal(); 
}

$('#menuSweetness').on('input', function() { 
    $('#sweetnessText').text($(this).val() + '%'); 
});

$('input[name="size"], input[name="toppings"]').change(updateMenuTotal);
$('#menuQty').change(updateMenuTotal);

function updateMenuTotal() {
    var size = $('input[name="size"]:checked').val() || 'Regular';
    var toppings = $('input[name="toppings"]:checked').length;
    var quantity = parseInt($('#menuQty').val()) || 1;
    var additionalPrice = 0;
    if (size === 'Large') additionalPrice += 20;
    if (size === 'Extra Large') additionalPrice += 35;
    additionalPrice += toppings * 15;
    var total = ((menuBasePrice || 0) + additionalPrice) * quantity;
    $('#menuTotal').text(total.toFixed(2));
}

function addMenuToCart() {
    var id = parseInt($('#menuItemId').val());
    var name = $('#menuItemName').val();
    var basePrice = parseFloat($('#menuItemPrice').val());
    var quantity = parseInt($('#menuQty').val());
    var size = $('input[name="size"]:checked').val();
    var sweetness = $('#menuSweetness').val();
    var iceLevel = $('input[name="iceLevel"]:checked').val();
    var toppings = $('input[name="toppings"]:checked').map(function() { return this.value; }).get().join(',');
    var specialInstructions = $('#menuInstructions').val();
    
    var form = document.createElement('form');
    form.method = 'POST';
    form.action = '@Url.Action("AddWithCustomization", "Cart")';
    
    var fields = { 
        id: id, 
        name: name, 
        price: basePrice, 
        quantity: quantity, 
        size: size, 
        sweetness: sweetness, 
        iceLevel: iceLevel, 
        toppings: toppings, 
        specialInstructions: specialInstructions, 
        isCustomizable: 'true' 
    };
    
    for (var key in fields) {
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = fields[key];
        form.appendChild(input);
    }
    
    document.body.appendChild(form);
    form.submit();
}
</script>