@model IEnumerable<CafeWebsite.Models.MenuItem>

@{
    ViewData["Title"] = "Menu";
}

<!-- Hero Carousel with Video -->
<div id="menuCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <!-- Video Slide - Full Screen HD -->
        <div class="carousel-item active" style="height: 60vh; min-height: 500px;">
            <video autoplay muted loop playsinline style="width: 100%; height: 100%; object-fit: cover;">
                <source src="~/Videos/istoriajo.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>
            <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center;">
                <div class="text-center" style="padding: 2rem;">
                    <h1 style="font-size: 4rem; color: white; margin-bottom: 1rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">ISTORIA COFFEE</h1>
                    <p style="color: rgba(255,255,255,0.9); font-size: 1.3rem; max-width: 500px; margin: 0 auto; text-shadow: 1px 1px 2px rgba(0,0,0,0.5);">Experience the finest coffee culture</p>
                </div>
    </div>
</div>
</div>
    </div>
</div>

<style>
    .carousel-item {
        transition: transform 0.8s ease-in-out;
    }
    
    #menuCarousel .carousel-control-prev,
    #menuCarousel .carousel-control-next {
        width: 5%;
        opacity: 0.5;
    }
    
    #menuCarousel .carousel-control-prev:hover,
    #menuCarousel .carousel-control-next:hover {
        opacity: 1;
    }
    
    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        filter: invert(1);
        width: 3rem;
        height: 3rem;
    }
</style>

<div class="menu-page">
<div class="container" style="margin-top: -3rem; position: relative; background: #fff; padding: 2rem; border-radius: 8px 8px 0 0; box-shadow: 0 10px 40px rgba(0,0,0,0.3); border: 1px solid #000;">
    <div class="category-filters" style="background: #f5f5f5; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid #000;">
        <button class="category-btn active" data-category="all" style="background: #000; color: #fff; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">All</button>
        <button class="category-btn" data-category="coffee" style="background: #fff; color: #000; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">Coffee</button>
        <button class="category-btn" data-category="non-coffee" style="background: #fff; color: #000; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">Non-Coffee</button>
        <button class="category-btn" data-category="specials" style="background: #fff; color: #000; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">Specials</button>
        <button class="category-btn" data-category="latte" style="background: #fff; color: #000; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">Latte</button>
        <button class="category-btn" data-category="pasta" style="background: #fff; color: #000; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">Pasta</button>
        <button class="category-btn" data-category="potato" style="background: #fff; color: #000; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">Potato</button>
        <button class="category-btn" data-category="chkn poppers" style="background: #fff; color: #000; border: 1px solid #000; padding: 0.5rem 1.2rem; margin: 0.2rem; border-radius: 4px; cursor: pointer;">Chkn Poppers</button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success" style="padding: 1rem; margin-bottom: 2rem;">
            @TempData["Success"]
        </div>
    }

    <div class="menu-grid">
        @foreach (var item in Model)
        {
            var isDrink = item.Category.ToLower() == "coffee" || item.Category.ToLower() == "non-coffee" || 
                          item.Category.ToLower() == "specials" || item.Category.ToLower() == "latte" ||
                          item.Category.ToLower() == "tea" || item.Category.ToLower() == "frappe" || 
                          item.Category.ToLower() == "milk tea";
            
            <div class="menu-item" data-category="@item.Category.ToLower()">
                <div class="menu-card">
                    <div class="card-img-wrapper">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name">
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="background: #f5f5f5;">
                                <i class="fas fa-mug-hot fa-3x" style="color: #ccc;"></i>
                            </div>
                        }
                        <div class="card-img-overlay">
                            <span class="category-tag">@item.Category</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <h5>@item.Name</h5>
                        <p class="description">@item.Description</p>
                        
                        @if (item.Rating > 0)
                        {
                            <div class="rating mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star" style="font-size: 0.75rem;"></i>
                                }
                                <span style="margin-left: 5px; color: #888;">@item.Rating.ToString("F1")</span>
                            </div>
                        }

                        <div class="price-row">
                            <span class="price">₱@item.Price.ToString("F2")</span>
                            <div style="display: flex; gap: 0.5rem;">
                                @if (isDrink)
                                {
                                    <button type="button" class="btn-customize" style="text-decoration: none; padding: 0.6rem 1.2rem; font-size: 0.7rem; cursor: pointer;"
                                            onclick="openCustomizeModal(@item.Id, '@item.Name', @item.Price, true)">
                                        <i class="fas fa-sliders-h"></i> Customize
                                    </button>
                                }
                                else
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="name" value="@item.Name" />
                                        <input type="hidden" name="price" value="@item.Price" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn-outline" style="text-decoration: none; padding: 0.5rem 1rem; font-size: 0.7rem; cursor: pointer;">
                                            <i class="fas fa-plus"></i> Add
                                        </button>
                                    </form>
                                }
                                <a href="@Url.Action("Details", "Menu", new { id = item.Id })" class="btn-outline" style="text-decoration: none; padding: 0.5rem 1rem; font-size: 0.7rem;">
                                    View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .menu-header {
        display: none;
    }
    
    /* Cement Theme Background with B&W Aesthetic */
    .menu-page {
        background: linear-gradient(135deg, #8a8a8a 0%, #6b6b6b 50%, #5c5c5c 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }
    
    .container[style*="margin-top: -3rem"] {
        background: #fff;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        border: 1px solid #000;
    }
    
    .category-filters {
        background: #f5f5f5;
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 2rem;
        border: 1px solid #000;
    }
    
    .category-btn {
        background: #fff;
        color: #000;
        border: 1px solid #000;
        padding: 0.5rem 1.2rem;
        margin: 0.2rem;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .category-btn:hover, .category-btn.active {
        background: #000;
        color: #fff;
    }
    
    .menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    
    .menu-item {
        background: #fff;
        border-radius: 12px;
        box-shadow: 5px 5px 15px rgba(0,0,0,0.2);
        border: 1px solid #000;
    }
    
    .menu-card {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
    }
    
    .card-body {
        background: #fff;
        padding: 1.5rem;
        color: #000;
    }
    
    .card-body h5 {
        color: #000;
        font-weight: 700;
    }
    
    .card-body .description {
        color: #333;
    }
    
    .price {
        color: #000;
        font-weight: 700;
        font-size: 1.3rem;
    }
    
    .btn-customize, .btn-outline {
        background: #000;
        color: #fff;
        border: 1px solid #000;
        border-radius: 4px;
    }
    
    .btn-customize:hover, .btn-outline:hover {
        background: #fff;
        color: #000;
    }
    
    .category-tag {
        background: #000;
        color: #fff;
    }
    
    .rating {
        color: #000;
    }
</style>

<!-- Customization Modal for Menu Page -->
<div class="modal fade" id="customizeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="background: #fff; border: 1px solid #000;">
            <div class="modal-header" style="background: #000; color: #fff; border-bottom: 1px solid #000;">
                <h5 class="modal-title"><i class="fas fa-coffee"></i> Craft Your Perfect Drink</h5>
                <button type="button" class="close" onclick="$('#customizeModal').modal('hide')" style="color: #fff;">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body" style="background: #fff; color: #000;">
                <form id="customizationForm">
                    <input type="hidden" id="menuItemId" />
                    <input type="hidden" id="menuItemName" />
                    <input type="hidden" id="menuItemPrice" />
                    
                    <div class="customize-item-header" style="background: #f5f5f5; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; border: 1px solid #000;">
                        <h4 id="modalItemName" style="color: #000;"></h4>
                        <p style="color: #333;">Base Price: ₱<span id="modalBasePrice"></span></p>
                    </div>
                    
                    <div class="option-group" style="margin-bottom: 1rem;">
                        <label style="color: #000; font-weight: 600;"><i class="fas fa-expand"></i> Size</label>
                        <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
                            <label style="display: flex; align-items: center; gap: 0.5rem; color: #000;">
                                <input type="radio" name="size" value="Regular" checked> Regular
                            </label>
                            <label style="display: flex; align-items: center; gap: 0.5rem; color: #000;">
                                <input type="radio" name="size" value="Large"> Large +₱20
                            </label>
                            <label style="display: flex; align-items: center; gap: 0.5rem; color: #000;">
                                <input type="radio" name="size" value="Extra Large"> XL +₱35
                            </label>
                        </div>
                    </div>
                    
                    <div class="option-group" style="margin-bottom: 1rem;">
                        <label style="color: #000; font-weight: 600;"><i class="fas fa-tint"></i> Sweetness</label>
                        <input type="range" id="menuSweetness" min="0" max="100" value="100" step="25" style="width: 100%;">
                        <div style="text-align: center; color: #000;"><span id="sweetnessText">100%</span></div>
                    </div>
                    
                    <div class="option-group" style="margin-bottom: 1rem;">
                        <label style="color: #000; font-weight: 600;"><i class="fas fa-cubes"></i> Ice Level</label>
                        <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem;">
                            <label style="color: #000;"><input type="radio" name="iceLevel" value="Regular" checked> Regular</label>
                            <label style="color: #000;"><input type="radio" name="iceLevel" value="Less Ice"> Less Ice</label>
                            <label style="color: #000;"><input type="radio" name="iceLevel" value="No Ice"> No Ice</label>
                            <label style="color: #000;"><input type="radio" name="iceLevel" value="Extra Ice"> Extra Ice</label>
                        </div>
                    </div>
                    
                    <div class="option-group" style="margin-bottom: 1rem;">
                        <label style="color: #000; font-weight: 600;"><i class="fas fa-plus-circle"></i> Toppings (+₱15 each)</label>
                        <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem;">
                            <label style="color: #000;"><input type="checkbox" name="toppings" value="Pearl"> Pearl</label>
                            <label style="color: #000;"><input type="checkbox" name="toppings" value="Coconut"> Coconut</label>
                            <label style="color: #000;"><input type="checkbox" name="toppings" value="Grass Jelly"> Grass Jelly</label>
                            <label style="color: #000;"><input type="checkbox" name="toppings" value="Pudding"> Pudding</label>
                            <label style="color: #000;"><input type="checkbox" name="toppings" value="Nata"> Nata</label>
                            <label style="color: #000;"><input type="checkbox" name="toppings" value="Cheese Foam"> Cheese Foam</label>
                        </div>
                    </div>
                    
                    <div class="option-group" style="margin-bottom: 1rem;">
                        <label style="color: #000; font-weight: 600;"><i class="fas fa-sticky-note"></i> Special Instructions</label>
                        <textarea id="menuInstructions" placeholder="Any special requests..." style="width: 100%; padding: 0.5rem; border: 1px solid #000; border-radius: 4px;"></textarea>
                    </div>
                    
                    <div style="margin-bottom: 1rem;">
                        <label style="color: #000; font-weight: 600;">Quantity</label>
                        <div style="display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem;">
                            <button type="button" onclick="menuDecreaseQty()" style="padding: 0.5rem 1rem; background: #000; color: #fff; border: 1px solid #000; border-radius: 4px;">-</button>
                            <input type="number" id="menuQty" value="1" min="1" style="width: 60px; padding: 0.5rem; border: 1px solid #000; border-radius: 4px;">
                            <button type="button" onclick="menuIncreaseQty()" style="padding: 0.5rem 1rem; background: #000; color: #fff; border: 1px solid #000; border-radius: 4px;">+</button>
                        </div>
                    </div>
                    
                    <div style="background: #000; padding: 1rem; border-radius: 8px; text-align: center;">
                        <span style="color: #fff; font-size: 1.2rem;">Total: ₱<span id="menuTotal" style="font-weight: 700; color: #fff;"></span></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="background: #f5f5f5; border-top: 1px solid #000;">
                <button type="button" onclick="$('#customizeModal').modal('hide')" style="padding: 0.75rem 1.5rem; background: #fff; color: #000; border: 1px solid #000; border-radius: 4px; cursor: pointer;">Cancel</button>
                <button type="button" onclick="addMenuToCart()" style="padding: 0.75rem 1.5rem; background: #000; color: #fff; border: 1px solid #000; border-radius: 4px; cursor: pointer;">
                    <i class="fas fa-shopping-cart"></i> Add to Cart
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    var menuBasePrice = 0;
    
    function openCustomizeModal(id, name, price, isCustomizable) {
        if (!isCustomizable) return;
        
        $('#menuItemId').val(id);
        $('#menuItemName').val(name);
        $('#menuItemPrice').val(price);
        $('#modalItemName').text(name);
        $('#modalBasePrice').text(price.toFixed(2));
        menuBasePrice = price;
        
        // Reset form
        $('input[name="size"][value="Regular"]').prop('checked', true);
        $('#menuSweetness').val(100);
        $('#sweetnessText').text('100%');
        $('input[name="iceLevel"][value="Regular"]').prop('checked', true);
        $('input[name="toppings"]').prop('checked', false);
        $('#menuInstructions').val('');
        $('#menuQty').val(1);
        
        updateMenuTotal();
        $('#customizeModal').modal('show');
    }
    
    function menuIncreaseQty() {
        var qty = parseInt($('#menuQty').val());
        $('#menuQty').val(qty + 1);
        updateMenuTotal();
    }
    
    function menuDecreaseQty() {
        var qty = parseInt($('#menuQty').val());
        if (qty > 1) {
            $('#menuQty').val(qty - 1);
            updateMenuTotal();
        }
    }
    
    $('#menuSweetness').on('input', function() {
        $('#sweetnessText').text($(this).val() + '%');
    });
    
    $('input[name="size"], input[name="toppings"]').change(updateMenuTotal);
    $('#menuQty').change(updateMenuTotal);
    
    function updateMenuTotal() {
        var size = $('input[name="size"]:checked').val();
        var toppings = $('input[name="toppings"]:checked').length;
        var quantity = parseInt($('#menuQty').val()) || 1;
        
        var additionalPrice = 0;
        if (size === 'Large') additionalPrice += 20;
        if (size === 'Extra Large') additionalPrice += 35;
        additionalPrice += toppings * 15;
        
        var total = (menuBasePrice + additionalPrice) * quantity;
        $('#menuTotal').text(total.toFixed(2));
    }
    
    function addMenuToCart() {
        var id = $('#menuItemId').val();
        var name = $('#menuItemName').val();
        var basePrice = parseFloat($('#menuItemPrice').val());
        var quantity = $('#menuQty').val();
        var size = $('input[name="size"]:checked').val();
        var sweetness = $('#menuSweetness').val();
        var iceLevel = $('input[name="iceLevel"]:checked').val();
        var toppings = $('input[name="toppings"]:checked').map(function() { return this.value; }).get().join(',');
        var specialInstructions = $('#menuInstructions').val();
        
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '@Url.Action("AddWithCustomization", "Cart")';
        
        var fields = {
            id: id,
            name: name,
            price: basePrice,
            quantity: quantity,
            size: size,
            sweetness: sweetness,
            iceLevel: iceLevel,
            toppings: toppings,
            specialInstructions: specialInstructions,
            isCustomizable: 'true'
        };
        
        for (var key in fields) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = fields[key];
            form.appendChild(input);
        }
        
        document.body.appendChild(form);
        form.submit();
    }
</script>
