@{
    ViewData["Title"] = "Live Chat";
}

<!-- SignalR client loaded from CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"
        asp-fallback-href-include="**/signalr.min.js"
        asp-fallback-test="window.signalR"
        crossorigin="anonymous"></script>

<div class="chat-page">
    @if (ViewBag.ChatError != null)
    {
        <div class="chat-error-banner" id="chatErrorBanner">@ViewBag.ChatError</div>
    }
    <div class="chat-container" id="chatContainer">
        <div class="chat-header">
            <div class="chat-header-info">
                <i class="fas fa-comments chat-header-icon"></i>
                <div>
                    <h2>Chat with Us</h2>
                    <span class="chat-status"><span class="status-dot online"></span> We typically reply within a few minutes</span>
                </div>
            </div>
            <button class="chat-close" id="chatClose" aria-label="Close chat">&times;</button>
        </div>

        <div class="chat-messages" id="chatMessages">
            <div class="chat-system-msg">
                <i class="fas fa-coffee"></i> Welcome to Istoria Coffee live chat! How can we help you today?
            </div>
        </div>

        <form method="post" asp-action="Index" asp-controller="Chat" id="chatForm" class="chat-input-area">
            @Html.AntiForgeryToken()
            <div class="chat-name-row">
                <input type="text" id="chatVisitorName" placeholder="Your name (optional)" class="chat-name-input" maxlength="50" />
            </div>
            <div class="chat-send-row">
                <textarea id="chatMessageInput" placeholder="Type your message..." rows="1" required></textarea>
                <button type="submit" class="chat-send-btn" aria-label="Send">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </form>
    </div>
</div>
