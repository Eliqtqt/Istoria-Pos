@model CafeWebsite.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #2c1810 0%, #1a0f0a 50%, #0d0705 100%);
        padding: 2.5rem;
        margin-bottom: 2rem;
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(44, 24, 16, 0.4);
        border: 1px solid rgba(212, 175, 135, 0.2);
    }
    
    .admin-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2rem;
        font-weight: 400;
        letter-spacing: 1px;
    }
    
    .admin-header p {
        opacity: 0.85;
        color: #d4af87;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
    }
    
    .stat-card {
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        padding: 1.75rem;
        transition: all 0.3s ease;
        height: 100%;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 32px rgba(44, 24, 16, 0.15);
    }
    
    .stat-card.dark {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        border: none;
    }
    
    .stat-card.dark .stat-icon {
        color: #d4af87;
        opacity: 0.9;
    }
    
    .stat-icon {
        font-size: 2.5rem;
        color: #2c1810;
        opacity: 0.15;
    }
    
    .section-card {
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }
    
    .section-card .card-header {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        border: none;
        padding: 1.25rem 1.5rem;
        font-family: 'Helvetica Neue', sans-serif;
        letter-spacing: 1px;
        font-size: 0.85rem;
    }
    
    .section-card.dark .card-header {
        background: #faf8f5;
        color: #2c1810;
        border-bottom: 1px solid #e8e0d8;
    }
    
    .section-card .card-body {
        padding: 1.5rem;
    }
    
    .action-btn {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 25px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        font-weight: 500;
        letter-spacing: 0.5px;
    }
    
    .action-btn:hover {
        background: linear-gradient(135deg, #4a2c20 0%, #2c1810 100%);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(44, 24, 16, 0.3);
    }
    
    .action-btn.outline {
        background: transparent;
        border: 1px solid #2c1810;
        color: #2c1810;
    }
    
    .action-btn.outline:hover {
        background: #2c1810;
        color: #fff;
    }
    
    .action-btn.white {
        background: #fff;
        color: #2c1810;
        border: 1px solid #fff;
    }
    
    .action-btn.white:hover {
        background: #f5f0eb;
        color: #2c1810;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .data-table th {
        background: #faf8f5;
        color: #2c1810;
        font-weight: 700;
        padding: 1rem 1.25rem;
        text-align: left;
        border-bottom: 2px solid #2c1810;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .data-table td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f0ebe5;
        color: #4a4a4a;
    }
    
    .data-table tr:hover {
        background: #faf8f5;
    }
    
    .badge-custom {
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .badge-pending {
        background: #fff3e0;
        color: #e65100;
        border: 1px solid #ffcc80;
    }
    
    .badge-confirmed {
        background: #e3f2fd;
        color: #1565c0;
        border: 1px solid #90caf9;
    }
    
    .badge-preparing {
        background: #f3e5f5;
        color: #7b1fa2;
        border: 1px solid #ce93d8;
    }
    
    .badge-ready {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #a5d6a7;
    }
    
    .badge-completed {
        background: #f5f5f5;
        color: #424242;
        border: 1px solid #e0e0e0;
    }
    
    .badge-cancelled {
        background: #ffebee;
        color: #c62828;
        border: 1px solid #ef9a9a;
    }
    
    .view-btn {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.5px;
    }
    
    .view-btn:hover {
        background: linear-gradient(135deg, #4a2c20 0%, #2c1810 100%);
        color: #fff;
    }
    
    .stat-number {
        font-size: 2.25rem;
        font-weight: 700;
        color: #2c1810;
        line-height: 1;
    }
    
    .stat-label {
        color: #8d6e63;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 0.5rem;
    }
    
    .stat-card.dark .stat-number {
        color: #d4af87;
    }
    
    .stat-card.dark .stat-label {
        color: #a89080;
    }
    
    .alert-custom {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
    }
    
    .alert-custom .btn-close {
        filter: invert(1);
    }
    
    .quick-action-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1.5rem 1rem;
        background: #faf8f5;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        transition: all 0.3s ease;
        text-decoration: none;
        color: #2c1810;
    }
    
    .quick-action-btn:hover {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(44, 24, 16, 0.2);
    }
    
    .quick-action-btn i {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        opacity: 0.7;
    }
    
    .quick-action-btn span {
        font-size: 0.8rem;
        font-weight: 500;
    }
</style>

<div class="container-fluid" style="padding: 2rem;">
    <!-- Admin Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-mug-hot" style="margin-right: 0.75rem; color: #d4af87;"></i> Admin Dashboard</h1>
                <p>Welcome back! Here's what's brewing today.</p>
            </div>
            <div style="text-align: right;">
                <p style="margin: 0; color: #d4af87;">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>
        </div>
    </div>
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show alert-custom" role="alert">
            <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-number">@Model.TotalOrders</div>
                        <div class="stat-label">Total Orders</div>
                    </div>
                    <i class="fas fa-shopping-bag stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card dark">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-number">@Model.TotalRevenue.ToString("C")</div>
                        <div class="stat-label">Total Revenue</div>
                    </div>
                    <i class="fas fa-coins stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-number">@Model.TotalMenuItems</div>
                        <div class="stat-label">Menu Items</div>
                    </div>
                    <i class="fas fa-coffee stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card dark">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-number">@Model.TotalUsers</div>
                        <div class="stat-label">Total Users</div>
                    </div>
                    <i class="fas fa-users stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats and Actions -->
    <div class="row mb-4">
        <div class="col-md-6 mb-4">
            <div class="section-card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-chart-line" style="margin-right: 0.5rem;"></i> Today's Summary</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="stat-number" style="font-size: 3rem;">@Model.TodayOrders</div>
                            <div class="stat-label">Orders Today</div>
                        </div>
                        <div class="col-6">
                            <div class="stat-number" style="font-size: 3rem;">@Model.PendingOrders</div>
                            <div class="stat-label">Pending Orders</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="section-card dark">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-bolt" style="margin-right: 0.5rem;"></i> Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <a asp-action="CreateMenuItem" class="quick-action-btn">
                                <i class="fas fa-plus-circle"></i>
                                <span>Add Menu Item</span>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-action="Orders" class="quick-action-btn">
                                <i class="fas fa-list-alt"></i>
                                <span>View Orders</span>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-action="Users" class="quick-action-btn">
                                <i class="fas fa-user-cog"></i>
                                <span>Manage Users</span>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-action="Events" class="quick-action-btn">
                                <i class="fas fa-calendar-star"></i>
                                <span>Event Manager</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="section-card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-history" style="margin-right: 0.5rem;"></i> Recent Orders</h5>
                <a asp-action="Orders" class="action-btn white" style="padding: 0.5rem 1rem; font-size: 0.85rem;">View All</a>
            </div>
        </div>
        <div class="card-body" style="padding: 0;">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                <td>@order.User?.Username ?? "Guest"</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td><strong>@order.TotalAmount.ToString("C")</strong></td>
                                <td>
                                    <span class="badge-custom @GetStatusBadgeClass(order.Status)">@order.Status</span>
                                </td>
                                <td>
                                    <a asp-action="OrderDetails" asp-route-id="@order.Id" class="view-btn">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "badge-pending",
            "Confirmed" => "badge-confirmed",
            "Preparing" => "badge-preparing",
            "Ready" => "badge-ready",
            "Completed" => "badge-completed",
            "Cancelled" => "badge-cancelled",
            _ => "badge-completed"
        };
    }
}