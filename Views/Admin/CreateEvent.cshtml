@model CafeWebsite.Models.Event
@{
    ViewData["Title"] = "Create Event";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #000 0%, #1a0f0a 50%, #0d0705 100%);
        padding: 2rem 3rem;
        margin-bottom: 2.5rem;
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(44, 24, 16, 0.4);
        border: 1px solid rgba(212, 175, 135, 0.2);
    }
    
    .admin-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.75rem;
        margin: 0;
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .page-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.75rem;
        margin: 0;
    }
    
    .divider {
        width: 60px;
        height: 1px;
        background: #000;
        margin: 0 auto 1rem;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 0.85rem 2rem;
        border-radius: 25px;
        border: none;
        font-weight: 600;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .btn-primary:hover {
        background: linear-gradient(135deg, #333 0%, #000 100%);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(44, 24, 16, 0.3);
    }
    
    .btn-outline {
        background: transparent;
        color: #000;
        padding: 0.85rem 2rem;
        border: 1px solid #000;
        border-radius: 25px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .btn-outline:hover {
        background: #000;
        color: #fff;
    }
    
    .form-card {
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }
    
    .form-card .card-header {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 1.25rem 1.5rem;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .form-card .card-body {
        padding: 2rem;
    }
    
    .form-label-custom {
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.75rem;
        color: #000;
        margin-bottom: 0.75rem;
        display: block;
    }
    
    .form-control-custom {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e8e0d8;
        border-radius: 12px;
        background: #faf8f5;
        color: #000;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .form-control-custom:focus {
        outline: none;
        border-color: #000;
        box-shadow: 0 0 0 3px rgba(44, 24, 16, 0.1);
    }
    
    .help-text {
        color: #666;
        font-size: 0.75rem;
        margin-top: 0.5rem;
    }
    
    .alert-error {
        background: linear-gradient(135deg, #c62828 0%, #b71c1c 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .alert-success {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
</style>

<div class="container-fluid" style="padding: 1rem 2rem 2.5rem;">
    <!-- Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <h1><i class="fas fa-calendar-star" style="margin-right: 0.75rem; color: #ccc;"></i> Create Event</h1>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert-error">
            <i class="fas fa-exclamation-circle"></i>
            @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            <i class="fas fa-check-circle"></i>
            @TempData["Success"]
        </div>
    }

    <div class="form-card">
        <div class="card-header">
            <i class="fas fa-calendar-plus"></i> Event Details
        </div>
        <div class="card-body">
            <form asp-action="CreateEvent" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="Title" class="form-label-custom">Title *</label>
                        <input type="text" id="Title" name="Title" class="form-control-custom" required placeholder="Enter event title" />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="Icon" class="form-label-custom">Icon</label>
                        <select id="Icon" name="Icon" class="form-control-custom">
                            <option value="fa-calendar">Calendar</option>
                            <option value="fa-coffee">Coffee</option>
                            <option value="fa-music">Music</option>
                            <option value="fa-leaf">Leaf</option>
                            <option value="fa-birthday-cake">Birthday</option>
                            <option value="fa-laptop">Laptop</option>
                            <option value="fa-palette">Art</option>
                            <option value="fa-users">Group</option>
                            <option value="fa-glass-cheers">Cheers</option>
                            <option value="fa-book">Book</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="Description" class="form-label-custom">Description *</label>
                    <textarea id="Description" name="Description" class="form-control-custom" rows="4" required placeholder="Describe your event..."></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="Schedule" class="form-label-custom">Schedule</label>
                        <input type="text" id="Schedule" name="Schedule" class="form-control-custom" placeholder="e.g., Every Saturday" />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="Time" class="form-label-custom">Time</label>
                        <input type="text" id="Time" name="Time" class="form-control-custom" placeholder="e.g., 10:00 AM - 12:00 PM" />
                    </div>
                </div>

                 <div class="mb-4">
                     <label for="ImageFile" class="form-label-custom">Event Image</label>
                     <input type="file" id="ImageFile" name="ImageFile" class="form-control-custom" accept="image/*" />
                     <div class="help-text">Supported formats: JPG, PNG, GIF, WebP</div>
                 </div>

                 <div class="row mb-4">
                     <div class="col-md-12">
                         <div class="form-check-custom">
                             <input type="checkbox" id="IsActive" name="IsActive" value="true" checked />
                             <label for="IsActive">Active (Show on website)</label>
                         </div>
                     </div>
                 </div>

                 <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                     <button type="submit" class="btn-primary">
                         <i class="fas fa-plus-circle" style="margin-right: 0.5rem;"></i> Create Event
                     </button>
                     <a asp-action="Events" class="btn-outline">
                         <i class="fas fa-arrow-left" style="margin-right: 0.5rem;"></i> Back to List
                     </a>
                 </div>
             </form>
         </div>
     </div>
</div>

