@model IEnumerable<CafeWebsite.Models.MenuItem>
@{
    ViewData["Title"] = "Menu Items";
}

<div class="page-header">
    <h1>Menu Items</h1>
    <div class="divider"></div>
    <a asp-action="CreateMenuItem" class="btn-primary" style="text-decoration: none; display: inline-block; margin-top: 1rem;">
        + Add New Item
    </a>
</div>

<div class="container">
    @if (TempData["Success"] != null)
    {
        <div class="alert-success" style="padding: 1rem; margin-bottom: 2rem;">
            @TempData["Success"]
        </div>
    }

    <div class="admin-card" style="padding: 0; overflow: hidden;">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="width: 60px;">ID</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Rating</th>
                    <th style="width: 100px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td><strong>@item.Name</strong></td>
                        <td><span style="background: #0a0a0a; color: white; padding: 0.3em 0.8em; font-size: 0.75rem;">@item.Category</span></td>
                        <td>₱@item.Price.ToString("F2")</td>
                        <td>
                            @if (item.Rating > 0)
                            {
                                <span><i class="fas fa-star" style="color: #0a0a0a;"></i> @item.Rating.ToString("F1")</span>
                            }
                            else
                            {
                                <span style="color: #888;">N/A</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a asp-action="EditMenuItem" asp-route-id="@item.Id" style="color: #0a0a0a; padding: 0.4rem 0.8rem; border: 1px solid #ddd; font-size: 0.8rem;" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="MenuDetails" asp-route-id="@item.Id" style="color: #0a0a0a; padding: 0.4rem 0.8rem; border: 1px solid #ddd; font-size: 0.8rem;" title="Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="DeleteMenuItem" asp-route-id="@item.Id" style="color: #fff; background: #0a0a0a; padding: 0.4rem 0.8rem; border: 1px solid #0a0a0a; font-size: 0.8rem;" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
