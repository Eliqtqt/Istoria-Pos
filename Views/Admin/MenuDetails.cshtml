@model CafeWebsite.Models.MenuItem
@{
    ViewData["Title"] = "Menu Item Details";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #000 0%, #1a0f0a 50%, #0d0705 100%);
        padding: 2rem;
        margin-bottom: 2rem;
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(44, 24, 16, 0.4);
    }
    
    .admin-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.75rem;
        margin: 0;
    }
    
    .back-btn {
        background: #fff;
        color: #000;
        padding: 0.6rem 1.25rem;
        border-radius: 25px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
    }
    
    .back-btn:hover {
        background: #f5f0eb;
        color: #000;
    }
    
    .info-card {
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }
    
    .info-card .card-header {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 1.25rem 1.5rem;
        border: none;
        font-size: 0.9rem;
    }
    
    .info-card .card-body {
        padding: 1.5rem;
    }
    
    .info-card .card-footer {
        background: #faf8f5;
        padding: 1rem 1.5rem;
        border-top: 1px solid #e8e0d8;
    }
    
    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 0.85rem 0;
        border-bottom: 1px solid #f0ebe5;
    }
    
    .info-item:last-child {
        border-bottom: none;
    }
    
    .info-item dt {
        color: #666;
        font-weight: 500;
    }
    
    .info-item dd {
        color: #000;
        font-weight: 600;
        margin: 0;
        text-align: right;
    }
    
    .badge-category {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .badge-dietary {
        background: #e8f5e9;
        color: #2e7d32;
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-right: 0.5rem;
    }
    
    .badge-rating {
        color: #ccc;
        font-weight: 600;
    }
    
    .badge-rating i {
        color: #ccc;
    }
    
    .no-rating {
        color: #999;
        font-style: italic;
    }
    
    .action-btn {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 0.6rem 1.25rem;
        border-radius: 25px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
        font-size: 0.85rem;
    }
    
    .action-btn:hover {
        background: linear-gradient(135deg, #333 0%, #000 100%);
        color: #fff;
    }
    
    .action-btn.danger {
        background: #c62828;
    }
    
    .action-btn.danger:hover {
        background: #b71c1c;
    }
    
    .action-btn.secondary {
        background: #666;
    }
    
    .action-btn.secondary:hover {
        background: #6d4c41;
    }
    
    .item-price {
        font-size: 1.5rem;
        font-weight: 700;
        color: #000;
    }
</style>

<div class="container-fluid" style="padding: 2rem;">
    <!-- Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <h1><i class="fas fa-coffee" style="margin-right: 0.75rem; color: #ccc;"></i> Menu Item Details</h1>
            <a asp-action="MenuItems" class="back-btn">
                <i class="fas fa-arrow-left" style="margin-right: 0.5rem;"></i> Back to Menu
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Item Details -->
        <div class="col-md-8 mb-4">
            <div class="info-card">
                <div class="card-header">
                    <i class="fas fa-mug-hot" style="margin-right: 0.5rem;"></i> @Model.Name
                </div>
                <div class="card-body">
                    <dl class="info-item">
                        <dt>ID</dt>
                        <dd>#@Model.Id</dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Name</dt>
                        <dd>@Model.Name</dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Category</dt>
                        <dd><span class="badge-category">@Model.Category</span></dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Description</dt>
                        <dd>@Model.Description</dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Price</dt>
                        <dd><span class="item-price">₱@Model.Price.ToString("F2")</span></dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Rating</dt>
                        <dd>
                            @if (Model.Rating > 0)
                            {
                                <span class="badge-rating"><i class="fas fa-star"></i> @Model.Rating.ToString("F1") (@Model.ReviewCount reviews)</span>
                            }
                            else
                            {
                                <span class="no-rating">No ratings yet</span>
                            }
                        </dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Dietary Info</dt>
                        <dd>
                            @if (Model.IsVegetarian) { <span class="badge-dietary">Vegetarian</span> }
                            @if (Model.IsVegan) { <span class="badge-dietary">Vegan</span> }
                            @if (Model.IsGlutenFree) { <span class="badge-dietary">Gluten Free</span> }
                            @if (!Model.IsVegetarian && !Model.IsVegan && !Model.IsGlutenFree)
                            {
                                <span class="no-rating">None</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <a asp-action="EditMenuItem" asp-route-id="@Model.Id" class="action-btn">
                        <i class="fas fa-edit" style="margin-right: 0.5rem;"></i> Edit
                    </a>
                    <a asp-action="DeleteMenuItem" asp-route-id="@Model.Id" class="action-btn danger" style="margin-left: 0.5rem;">
                        <i class="fas fa-trash" style="margin-right: 0.5rem;"></i> Delete
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
