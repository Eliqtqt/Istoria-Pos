@model CafeWebsite.Models.MenuItem
@{
    ViewData["Title"] = "Edit Menu Item";
    var categories = new[] { "All", "Coffee", "Non-Coffee", "Specials", "Latte", "Pasta", "Potato", "Chicken Poppers" };
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #000 0%, #1a0f0a 50%, #0d0705 100%);
        padding: 2rem;
        margin-bottom: 2rem;
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(44, 24, 16, 0.4);
    }
    
    .admin-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.75rem;
        margin: 0;
    }
    
    .back-btn {
        background: #fff;
        color: #000;
        padding: 0.6rem 1.25rem;
        border-radius: 25px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
    }
    
    .back-btn:hover {
        background: #f5f0eb;
        color: #000;
    }
    
    .form-card {
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }
    
    .form-card .card-header {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 1.25rem 1.5rem;
        font-size: 0.9rem;
    }
    
    .form-card .card-body {
        padding: 1.5rem;
    }
    
    .form-label-custom {
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.75rem;
        color: #000;
        margin-bottom: 0.5rem;
        display: block;
    }
    
    .form-control-custom {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e8e0d8;
        border-radius: 12px;
        background: #faf8f5;
        color: #000;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .form-control-custom:focus {
        outline: none;
        border-color: #000;
        box-shadow: 0 0 0 3px rgba(44, 24, 16, 0.1);
    }
    
    .input-group-custom {
        border: 1px solid #e8e0d8;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
    }
    
    .input-group-custom span {
        background: #faf8f5;
        padding: 0.75rem 1rem;
        border: none;
        color: #000;
        font-weight: 600;
    }
    
    .input-group-custom input {
        border: none;
        padding: 0.75rem 1rem;
        flex: 1;
        background: #faf8f5;
    }
    
    .input-group-custom input:focus {
        outline: none;
    }
    
    .form-check-custom {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .form-check-custom input {
        width: 18px;
        height: 18px;
        accent-color: #000;
    }
    
    .form-check-custom label {
        color: #000;
        font-weight: 500;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 0.85rem 2.5rem;
        border: none;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .btn-primary:hover {
        background: linear-gradient(135deg, #333 0%, #000 100%);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(44, 24, 16, 0.3);
    }
    
    .btn-outline {
        background: transparent;
        color: #000;
        padding: 0.85rem 2rem;
        border: 1px solid #000;
        border-radius: 25px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
    }
    
    .btn-outline:hover {
        background: #000;
        color: #fff;
    }
    
    .help-text {
        color: #666;
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }
    
    .image-preview {
        margin-top: 0.5rem;
    }
    
    .image-preview img {
        max-width: 80px;
        max-height: 80px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e8e0d8;
    }
</style>

<div class="container-fluid" style="padding: 2rem;">
    <!-- Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <h1><i class="fas fa-edit" style="margin-right: 0.75rem; color: #ccc;"></i> Edit Menu Item</h1>
            <a asp-action="MenuItems" class="back-btn">
                <i class="fas fa-arrow-left" style="margin-right: 0.5rem;"></i> Back to Menu
            </a>
        </div>
    </div>

    <div class="form-card">
        <div class="card-header">
            <i class="fas fa-coffee" style="margin-right: 0.5rem;"></i> @Model.Name
        </div>
        <div class="card-body">
            <form asp-action="EditMenuItem" asp-controller="Admin" method="post">
                <input type="hidden" name="Id" value="@Model.Id" />
                @Html.AntiForgeryToken()
                
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="Name" class="form-label-custom">Name *</label>
                        <input type="text" id="Name" name="Name" class="form-control-custom" value="@Model.Name" required />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="Category" class="form-label-custom">Category</label>
                        <select id="Category" name="Category" class="form-control-custom">
                            <option value="">Select Category</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="Description" class="form-label-custom">Description</label>
                    <textarea id="Description" name="Description" class="form-control-custom" rows="3">@Model.Description</textarea>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <label for="Price" class="form-label-custom">Price *</label>
                        <div class="input-group-custom">
                            <span>₱</span>
                            <input type="number" id="Price" name="Price" class="form-control-custom" step="0.01" min="0.01" value="@Model.Price" required style="border-radius: 0;" />
                        </div>
                    </div>
                    <div class="col-md-4 mb-4">
                        <label for="ImageUrl" class="form-label-custom">Image URL</label>
                        <input type="text" id="ImageUrl" name="ImageUrl" class="form-control-custom" value="@Model.ImageUrl" placeholder="Paste image URL here..." />
                        <div class="help-text">Right-click an image online → Copy image address → Paste here</div>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="image-preview">
                                <img src="@Model.ImageUrl" alt="Current" />
                            </div>
                        }
                    </div>
                    <div class="col-md-4 mb-4">
                        <label for="Rating" class="form-label-custom">Rating</label>
                        <input type="number" id="Rating" name="Rating" class="form-control-custom" step="0.1" min="0" max="5" value="@Model.Rating" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <label for="ReviewCount" class="form-label-custom">Review Count</label>
                        <input type="number" id="ReviewCount" name="ReviewCount" class="form-control-custom" min="0" value="@Model.ReviewCount" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="form-check-custom">
                            <input type="checkbox" id="IsVegetarian" name="IsVegetarian" value="true" @(Model.IsVegetarian ? "checked" : "") />
                            <label for="IsVegetarian">Vegetarian</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check-custom">
                            <input type="checkbox" id="IsVegan" name="IsVegan" value="true" @(Model.IsVegan ? "checked" : "") />
                            <label for="IsVegan">Vegan</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check-custom">
                            <input type="checkbox" id="IsGlutenFree" name="IsGlutenFree" value="true" @(Model.IsGlutenFree ? "checked" : "") />
                            <label for="IsGlutenFree">Gluten Free</label>
                        </div>
                    </div>
                </div>

                <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                    <button type="submit" class="btn-primary">
                        <i class="fas fa-save" style="margin-right: 0.5rem;"></i> Save Changes
                    </button>
                    <a asp-action="MenuItems" class="btn-outline">
                        <i class="fas fa-arrow-left" style="margin-right: 0.5rem;"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
