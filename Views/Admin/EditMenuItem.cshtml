@model CafeWebsite.Models.MenuItem
@{
    ViewData["Title"] = "Edit Menu Item";
    var categories = new[] { "Coffee", "Tea", "Pastry", "Food", "Dessert", "Beverage" };
}

<div class="page-header">
    <h1>Edit Menu Item</h1>
    <div class="divider"></div>
</div>

<div class="container">
    <div class="admin-card">
        <form asp-action="EditMenuItem" asp-controller="Admin" method="post">
            <input type="hidden" name="Id" value="@Model.Id" />
            @Html.AntiForgeryToken()
            
            <div class="row">
                <div class="col-md-6 mb-4">
                    <label for="Name" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Name *</label>
                    <input type="text" id="Name" name="Name" class="form-control" value="@Model.Name" required style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                </div>
                <div class="col-md-6 mb-4">
                    <label for="Category" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Category</label>
                    <select id="Category" name="Category" class="form-select" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0;">
                        <option value="">Select Category</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label for="Description" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Description</label>
                <textarea id="Description" name="Description" class="form-control" rows="3" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0;">@Model.Description</textarea>
            </div>

            <div class="row">
                <div class="col-md-4 mb-4">
                    <label for="Price" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Price *</label>
                    <div class="input-group" style="border-bottom: 1px solid #ddd;">
                        <span style="background: transparent; border: none; padding: 0.8rem 0; color: #0a0a0a; font-weight: 600;">₱</span>
                        <input type="number" id="Price" name="Price" class="form-control" step="0.01" min="0.01" value="@Model.Price" required style="border: none; border-radius: 0; padding: 0.8rem 0;" />
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <label for="ImageUrl" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Image URL</label>
                    <input type="text" id="ImageUrl" name="ImageUrl" class="form-control" value="@Model.ImageUrl" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                </div>
                <div class="col-md-4 mb-4">
                    <label for="Rating" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Rating</label>
                    <input type="number" id="Rating" name="Rating" class="form-control" step="0.1" min="0" max="5" value="@Model.Rating" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-4">
                    <label for="ReviewCount" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Review Count</label>
                    <input type="number" id="ReviewCount" name="ReviewCount" class="form-control" min="0" value="@Model.ReviewCount" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="checkbox" id="IsVegetarian" name="IsVegetarian" class="form-check-input" value="true" @(Model.IsVegetarian ? "checked" : "") style="accent-color: #0a0a0a;" />
                        <label for="IsVegetarian" class="form-check-label" style="margin-left: 0.5rem;">Vegetarian</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="checkbox" id="IsVegan" name="IsVegan" class="form-check-input" value="true" @(Model.IsVegan ? "checked" : "") style="accent-color: #0a0a0a;" />
                        <label for="IsVegan" class="form-check-label" style="margin-left: 0.5rem;">Vegan</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="checkbox" id="IsGlutenFree" name="IsGlutenFree" class="form-check-input" value="true" @(Model.IsGlutenFree ? "checked" : "") style="accent-color: #0a0a0a;" />
                        <label for="IsGlutenFree" class="form-check-label" style="margin-left: 0.5rem;">Gluten Free</label>
                    </div>
                </div>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn-primary" style="padding: 1rem 3rem;">Save Changes</button>
                <a asp-action="MenuItems" class="btn-outline" style="text-decoration: none; padding: 1rem 2rem;">
                    ← Back to List
                </a>
            </div>
        </form>
    </div>
</div>
