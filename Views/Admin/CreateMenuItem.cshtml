@model CafeWebsite.Models.MenuItem
@{
    ViewData["Title"] = "Create Menu Item";
}

<div style="background: #f8f8f8; padding: 1.5rem 0; text-align: center; border-bottom: 1px solid #ddd; margin-bottom: 2rem;">
    <div style="max-width: 600px; margin: 0 auto;">
        <h1 style="font-size: 1.75rem; margin-bottom: 0.5rem; font-weight: 600;">Create Menu Item</h1>
        <p style="font-size: 0.8rem; color: #555; margin: 0; font-family: Georgia, serif; font-style: italic;">[is-tor-yuh] • noun</p>
        <p style="font-size: 0.75rem; color: #777; margin: 0.25rem 0 0 0;">a place of laughter, comfort and acceptance; where memories are made over a cup of coffee and friends.</p>
        <div style="width: 50px; height: 1px; background: #0a0a0a; margin: 0.75rem auto 0;"></div>
    </div>
</div>

<div class="container">
    @if (TempData["Error"] != null)
    {
        <div class="alert-danger" style="padding: 1rem; margin-bottom: 2rem;">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert-success" style="padding: 1rem; margin-bottom: 2rem;">@TempData["Success"]</div>
    }

    <div class="admin-card">
        <form asp-action="CreateMenuItem" method="post">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-6 mb-4">
                    <label for="Name" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Name *</label>
                    <input type="text" id="Name" name="Name" class="form-control" required style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                </div>
                <div class="col-md-6 mb-4">
                    <label for="Category" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Category</label>
                    <select id="Category" name="Category" class="form-select" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0;">
                        <option value="">Select Category</option>
                        <option value="All">All</option>
                        <option value="Coffee">Coffee</option>
                        <option value="Non-Coffee">Non-Coffee</option>
                        <option value="Specials">Specials</option>
                        <option value="Latte">Latte</option>
                        <option value="Pasta">Pasta</option>
                        <option value="Pastry">Pastry</option>
                        <option value="Potato">Potato</option>
                        <option value="Chicken Poppers">Chicken Poppers</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label for="Description" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Description</label>
                <textarea id="Description" name="Description" class="form-control" rows="3" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0;"></textarea>
            </div>

            <div class="row">
                <div class="col-md-4 mb-4">
                    <label for="Price" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Price *</label>
                    <div class="input-group" style="border-bottom: 1px solid #ddd;">
                        <span style="background: transparent; border: none; padding: 0.8rem 0; color: #0a0a0a; font-weight: 600;">₱</span>
                        <input type="number" id="Price" name="Price" class="form-control" step="0.01" min="0.01" required style="border: none; border-radius: 0; padding: 0.8rem 0;" />
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <label for="ImageUrl" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Image URL</label>
                    <input type="text" id="ImageUrl" name="ImageUrl" class="form-control" placeholder="Paste image URL here..." style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                    <small style="color: #888; font-size: 0.7rem;">Right-click an image online → Copy image address → Paste here</small>
                </div>
                <div class="col-md-4 mb-4">
                    <label for="Rating" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Rating</label>
                    <input type="number" id="Rating" name="Rating" class="form-control" step="0.1" min="0" max="5" value="0" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-4">
                    <label for="ReviewCount" class="form-label" style="font-weight: 500; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">Review Count</label>
                    <input type="number" id="ReviewCount" name="ReviewCount" class="form-control" min="0" value="0" style="border: none; border-bottom: 1px solid #ddd; border-radius: 0; padding: 0.8rem 0;" />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="checkbox" id="IsVegetarian" name="IsVegetarian" class="form-check-input" value="true" style="accent-color: #0a0a0a;" />
                        <label for="IsVegetarian" class="form-check-label" style="margin-left: 0.5rem;">Vegetarian</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="checkbox" id="IsVegan" name="IsVegan" class="form-check-input" value="true" style="accent-color: #0a0a0a;" />
                        <label for="IsVegan" class="form-check-label" style="margin-left: 0.5rem;">Vegan</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="checkbox" id="IsGlutenFree" name="IsGlutenFree" class="form-check-input" value="true" style="accent-color: #0a0a0a;" />
                        <label for="IsGlutenFree" class="form-check-label" style="margin-left: 0.5rem;">Gluten Free</label>
                    </div>
                </div>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn-primary" style="padding: 1rem 3rem;">Create Item</button>
                <a asp-action="MenuItems" class="btn-outline" style="text-decoration: none; padding: 1rem 2rem;">
                    ← Back to List
                </a>
            </div>
        </form>
    </div>
</div>
