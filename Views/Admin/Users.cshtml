@model IEnumerable<CafeWebsite.Models.User>
@{
    ViewData["Title"] = "Users";
}

<style>
    /* Coffee Shop Theme - Warm & Inviting */
    .admin-header {
        background: linear-gradient(135deg, #3e2723 0%, #5d4037 50%, #4e342e 100%);
        padding: 2.5rem;
        margin-bottom: 2rem;
        border-radius: 12px;
        color: #fff;
        border-left: 5px solid #d7ccc8;
        box-shadow: 0 8px 32px rgba(62, 39, 35, 0.3);
    }
    
    .admin-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2.2rem;
        font-weight: 600;
        letter-spacing: 1px;
    }
    
    .admin-header p {
        font-size: 0.95rem;
        letter-spacing: 0.5px;
        opacity: 0.85;
        color: #d7ccc8;
    }
    
    .section-card {
        background: #fff;
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        overflow: hidden;
    }
    
    .section-card .card-header {
        background: linear-gradient(135deg, #5d4037 0%, #4e342e 100%);
        color: #fff;
        padding: 1.5rem 2rem;
        border: none;
        font-family: 'Helvetica Neue', sans-serif;
        letter-spacing: 1px;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .section-card .card-header::before {
        content: "☕";
        font-size: 1.2rem;
    }
    
    .section-card .card-body {
        padding: 0;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .data-table th {
        background: #faf8f5;
        color: #3e2723;
        font-weight: 700;
        padding: 1.25rem 1.5rem;
        text-align: left;
        border-bottom: 2px solid #d7ccc8;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }
    
    .data-table td {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #eee8e5;
        color: #4a4a4a;
        font-size: 0.95rem;
        vertical-align: middle;
    }
    
    .data-table tr:last-child td {
        border-bottom: none;
    }
    
    .data-table tr:hover {
        background: linear-gradient(90deg, #faf8f5 0%, #f5f0eb 100%);
    }
    
    .data-table tr {
        transition: all 0.2s ease;
    }
    
    /* Coffee-themed badges */
    .badge-custom {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .badge-admin {
        background: linear-gradient(135deg, #3e2723 0%, #5d4037 100%);
        color: #fff;
        box-shadow: 0 2px 8px rgba(62, 39, 35, 0.3);
    }
    
    .badge-customer {
        background: #f5f0eb;
        color: #5d4037;
        border: 1px solid #d7ccc8;
    }
    
    .badge-orders {
        background: linear-gradient(135deg, #8d6e63 0%, #6d4c41 100%);
        color: #fff;
        padding: 0.4rem 0.8rem;
        font-size: 0.75rem;
        font-weight: 500;
    }
    
    /* Coffee cup styled view button */
    .view-btn {
        background: linear-gradient(135deg, #6d4c41 0%, #5d4037 100%);
        color: #fff;
        padding: 0.6rem 1.25rem;
        border-radius: 25px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 2px 8px rgba(93, 64, 55, 0.3);
    }
    
    .view-btn:hover {
        background: linear-gradient(135deg, #5d4037 0%, #3e2723 100%);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(62, 39, 35, 0.4);
    }
    
    /* Cream colored alert */
    .alert-custom {
        background: linear-gradient(135deg, #faf8f5 0%, #f5f0eb 100%);
        color: #3e2723;
        border: 1px solid #d7ccc8;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
    }
    
    .alert-custom .btn-close {
        filter: invert(0.3);
    }
    
    .empty-state {
        padding: 5rem 2rem;
        text-align: center;
    }
    
    .empty-state i {
        color: #bcaaa4;
        font-size: 4rem;
        margin-bottom: 1rem;
    }
    
    .empty-state p {
        color: #8d6e63;
        font-size: 1.1rem;
    }
    
    /* Coffee bean styled avatar */
    .user-avatar {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #6d4c41 0%, #4e342e 100%);
        color: #fff;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        margin-right: 0.75rem;
        box-shadow: 0 2px 8px rgba(62, 39, 35, 0.3);
        font-size: 1.1rem;
    }
    
    .user-cell {
        display: flex;
        align-items: center;
    }
    
    .user-info {
        display: flex;
        flex-direction: column;
    }
    
    .user-name {
        font-weight: 600;
        color: #3e2723;
    }
    
    .user-email {
        font-size: 0.8rem;
        color: #8d6e63;
        margin-top: 2px;
    }
    
    /* Stats row */
    .stats-row {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    
    .stat-card {
        background: linear-gradient(135deg, #faf8f5 0%, #f5f0eb 100%);
        border: 1px solid #d7ccc8;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        flex: 1;
        min-width: 150px;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: all 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(62, 39, 35, 0.15);
    }
    
    .stat-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #6d4c41 0%, #5d4037 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.3rem;
    }
    
    .stat-content h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 700;
        color: #3e2723;
    }
    
    .stat-content p {
        margin: 0;
        font-size: 0.8rem;
        color: #8d6e63;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    /* Coffee steam decoration */
    .coffee-steam {
        position: absolute;
        top: -20px;
        right: 20px;
        font-size: 2rem;
        opacity: 0.3;
    }
    
    /* Search bar styling */
    .search-container {
        padding: 1rem 1.5rem;
        background: #faf8f5;
        border-bottom: 1px solid #eee8e5;
    }
    
    .search-input {
        width: 100%;
        max-width: 300px;
        padding: 0.75rem 1rem;
        border: 1px solid #d7ccc8;
        border-radius: 25px;
        background: #fff;
        color: #3e2723;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }
    
    .search-input:focus {
        outline: none;
        border-color: #6d4c41;
        box-shadow: 0 0 0 3px rgba(109, 76, 65, 0.1);
    }
    
    .search-input::placeholder {
        color: #bcaaa4;
    }
    
    /* Row actions */
    .row-actions {
        display: flex;
        gap: 0.5rem;
    }
    
    .action-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 0.85rem;
    }
    
    .action-icon:hover {
        transform: scale(1.1);
    }
    
    .view-icon {
        background: linear-gradient(135deg, #6d4c41 0%, #5d4037 100%);
    }
    
    .edit-icon {
        background: linear-gradient(135deg, #8d6e63 0%, #6d4c41 100%);
    }
</style>

<div class="container-fluid" style="padding: 2rem; position: relative;">
    <!-- Coffee Steam Decoration -->
    <div class="coffee-steam">☕ ☕ ☕</div>
    
    <!-- Admin Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-users" style="margin-right: 0.75rem;"></i> Users</h1>
                <p>Manage your coffee shop customers and team members</p>
            </div>
            <div style="text-align: right;">
                <p style="margin: 0; font-size: 0.85rem;">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count()</h3>
                <p>Total Users</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-user-check"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "Customer")</h3>
                <p>Customers</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-user-shield"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Count(u => u.Role == "Admin")</h3>
                <p>Admins</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-coffee"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.Sum(u => u.Orders?.Count ?? 0)</h3>
                <p>Total Orders</p>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="section-card">
        <div class="card-header">
            <i class="fas fa-list" style="margin-right: 0.5rem;"></i> Customer & Team Directory
        </div>
        
        <!-- Search Bar -->
        <div class="search-container">
            <input type="text" class="search-input" placeholder="🔍 Search customers by name or email..." id="userSearch">
        </div>
        
        <div class="card-body">
            <div class="table-responsive">
                <table class="data-table" id="usersTable">
                    <thead>
                        <tr>
                            <th><i class="fas fa-hashtag" style="margin-right: 0.5rem;"></i>ID</th>
                            <th><i class="fas fa-user" style="margin-right: 0.5rem;"></i>Customer</th>
                            <th><i class="fas fa-envelope" style="margin-right: 0.5rem;"></i>Email</th>
                            <th><i class="fas fa-star" style="margin-right: 0.5rem;"></i>Role</th>
                            <th><i class="fas fa-shopping-bag" style="margin-right: 0.5rem;"></i>Orders</th>
                            <th><i class="fas fa-cogs" style="margin-right: 0.5rem;"></i>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td><span style="color: #bcaaa4; font-weight: 600;">#</span><span style="color: #8d6e63;">@user.Id</span></td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">☕ @user.Username[0].ToString().ToUpper()</div>
                                        <div class="user-info">
                                            <span class="user-name">@user.Username</span>
                                        </div>
                                    </div>
                                </td>
                                <td style="color: #6d4c41;">@user.Email</td>
                                <td>
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge-custom badge-admin"><i class="fas fa-crown" style="font-size: 0.65rem; margin-right: 4px;"></i> Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-customer"><i class="fas fa-mug-hot" style="font-size: 0.65rem; margin-right: 4px;"></i> Customer</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge-custom badge-orders"><i class="fas fa-coffee" style="margin-right: 4px;"></i> @user.Orders?.Count orders</span>
                                </td>
                                <td>
                                    <div class="row-actions">
                                        <a asp-action="UserDetails" asp-route-id="@user.Id" class="action-icon view-icon" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div style="font-size: 4rem; margin-bottom: 1rem;">☕</div>
                <p>No customers found yet. Your coffee shop is just getting started!</p>
            </div>
        }
    </div>
</div>

<script>
    // Simple search functionality
    document.getElementById('userSearch').addEventListener('keyup', function() {
        const searchTerm = this.value.toLowerCase();
        const table = document.getElementById('usersTable');
        const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
        
        for (let i = 0; i < rows.length; i++) {
            const username = rows[i].cells[1].textContent.toLowerCase();
            const email = rows[i].cells[2].textContent.toLowerCase();
            
            if (username.includes(searchTerm) || email.includes(searchTerm)) {
                rows[i].style.display = '';
            } else {
                rows[i].style.display = 'none';
            }
        }
    });
</script>
