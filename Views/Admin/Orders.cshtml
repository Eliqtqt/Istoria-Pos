@model IEnumerable<CafeWebsite.Models.Order>
@{
    ViewData["Title"] = "Orders";
    var currentStatus = Context.Request.Query["status"].ToString();
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #2c1810 0%, #1a0f0a 50%, #0d0705 100%);
        padding: 2.5rem;
        margin-bottom: 2rem;
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(44, 24, 16, 0.4);
        border: 1px solid rgba(212, 175, 135, 0.2);
    }
    
    .admin-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2rem;
        font-weight: 400;
        letter-spacing: 1px;
    }
    
    .admin-header p {
        font-size: 0.95rem;
        opacity: 0.85;
        color: #d4af87;
    }
    
    .section-card {
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
        overflow: hidden;
    }
    
    .section-card .card-header {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        padding: 1.25rem 1.5rem;
        border: none;
        font-family: 'Helvetica Neue', sans-serif;
        letter-spacing: 1px;
        font-size: 0.85rem;
    }
    
    .section-card .card-body {
        padding: 0;
    }
    
    .filter-container {
        background: #fff;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }
    
    .filter-btn {
        background: #fff;
        color: #2c1810;
        border: 1px solid #e8e0d8;
        padding: 0.6rem 1.25rem;
        transition: all 0.3s ease;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 25px;
    }
    
    .filter-btn:hover {
        background: #2c1810;
        color: #fff;
        border-color: #2c1810;
    }
    
    .filter-btn.active {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        border-color: #2c1810;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .data-table th {
        background: #faf8f5;
        color: #2c1810;
        font-weight: 700;
        padding: 1rem 1.25rem;
        text-align: left;
        border-bottom: 2px solid #2c1810;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .data-table td {
        padding: 1.25rem 1.25rem;
        border-bottom: 1px solid #f0ebe5;
        color: #4a4a4a;
        font-size: 0.9rem;
    }
    
    .data-table tr:last-child td {
        border-bottom: none;
    }
    
    .data-table tr:hover {
        background: #faf8f5;
    }
    
    .badge-custom {
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
    }
    
    .badge-pending {
        background: #fff3e0;
        color: #e65100;
        border: 1px solid #ffcc80;
    }
    
    .badge-confirmed {
        background: #e3f2fd;
        color: #1565c0;
        border: 1px solid #90caf9;
    }
    
    .badge-preparing {
        background: #f3e5f5;
        color: #7b1fa2;
        border: 1px solid #ce93d8;
    }
    
    .badge-ready {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #a5d6a7;
    }
    
    .badge-completed {
        background: #f5f5f5;
        color: #424242;
        border: 1px solid #e0e0e0;
    }
    
    .badge-cancelled {
        background: #ffebee;
        color: #c62828;
        border: 1px solid #ef9a9a;
    }
    
    .badge-items {
        background: transparent;
        color: #8d6e63;
        border: 1px solid #e8e0d8;
        padding: 0.3rem 0.6rem;
        font-size: 0.7rem;
        border-radius: 20px;
    }
    
    .view-btn {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.75rem;
        font-weight: 500;
    }
    
    .view-btn:hover {
        background: linear-gradient(135deg, #4a2c20 0%, #2c1810 100%);
        color: #fff;
    }
    
    .alert-custom {
        background: linear-gradient(135deg, #2c1810 0%, #4a2c20 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-size: 0.9rem;
    }
    
    .alert-custom .btn-close {
        filter: invert(1);
    }
    
    .empty-state {
        padding: 5rem 2rem;
        text-align: center;
    }
    
    .empty-state i {
        color: #d4af87;
        font-size: 4rem;
        margin-bottom: 1rem;
    }
    
    .empty-state p {
        color: #8d6e63;
        font-size: 1rem;
    }
    
    .order-id {
        font-weight: 600;
        color: #2c1810;
    }
    
    .order-total {
        font-weight: 700;
        color: #2c1810;
    }
</style>

<div class="container-fluid" style="padding: 2rem;">
    <!-- Admin Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-shopping-bag" style="margin-right: 0.75rem; color: #d4af87;"></i> Orders</h1>
                <p>Manage and track all customer orders</p>
            </div>
            <div style="text-align: right;">
                <p style="margin: 0; color: #d4af87;">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Status Filter -->
    <div class="filter-container">
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Orders" class="btn filter-btn @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">
                All Orders
            </a>
            <a asp-action="Orders" asp-route-status="Pending" class="btn filter-btn @(currentStatus == "Pending" ? "active" : "")">
                Pending
            </a>
            <a asp-action="Orders" asp-route-status="Confirmed" class="btn filter-btn @(currentStatus == "Confirmed" ? "active" : "")">
                Confirmed
            </a>
            <a asp-action="Orders" asp-route-status="Preparing" class="btn filter-btn @(currentStatus == "Preparing" ? "active" : "")">
                Preparing
            </a>
            <a asp-action="Orders" asp-route-status="Ready" class="btn filter-btn @(currentStatus == "Ready" ? "active" : "")">
                Ready
            </a>
            <a asp-action="Orders" asp-route-status="Completed" class="btn filter-btn @(currentStatus == "Completed" ? "active" : "")">
                Completed
            </a>
        </div>
    </div>

    <div class="section-card">
        <div class="card-header">
            <i class="fas fa-list" style="margin-right: 0.5rem;"></i> Order List
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Items</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><span class="order-id">#@order.Id</span></td>
                                <td>@order.User?.Username ?? "Guest"</td>
                                <td style="color: #8d6e63;">@order.OrderDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td><span class="order-total">@order.TotalAmount.ToString("C")</span></td>
                                <td>
                                    <span class="badge-custom @GetStatusBadgeClass(order.Status)">@order.Status</span>
                                </td>
                                <td>
                                    <span class="badge-custom badge-items">@order.OrderItems?.Count items</span>
                                </td>
                                <td>
                                    <a asp-action="OrderDetails" asp-route-id="@order.Id" class="view-btn">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-box-open"></i>
                <p>No orders found.</p>
            </div>
        }
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "badge-pending",
            "Confirmed" => "badge-confirmed",
            "Preparing" => "badge-preparing",
            "Ready" => "badge-ready",
            "Completed" => "badge-completed",
            "Cancelled" => "badge-cancelled",
            _ => "badge-completed"
        };
    }
}
