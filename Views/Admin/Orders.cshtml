@model IEnumerable<CafeWebsite.Models.Order>
@{
    ViewData["Title"] = "Orders";
    var currentStatus = Context.Request.Query["status"].ToString();
}

<style>
    .admin-header {
        background: #000;
        padding: 2rem 3rem;
        margin-bottom: 2.5rem;
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }
    
    .admin-header h1 {
        font-family: 'Helvetica Neue', sans-serif;
        font-size: 2rem;
        font-weight: 300;
        letter-spacing: 2px;
    }
    
    .admin-header p {
        font-size: 0.95rem;
        opacity: 0.7;
        color: #ccc;
    }
    
    .section-card {
        background: #fff;
        border: 1px solid #000;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
        overflow: hidden;
    }
    
    .section-card .card-header {
        background: #000;
        color: #fff;
        padding: 1.25rem 1.5rem;
        border: none;
        font-family: 'Helvetica Neue', sans-serif;
        letter-spacing: 2px;
        font-size: 0.85rem;
    }
    
    .section-card .card-body {
        padding: 1.5rem;
    }
    
    .filter-container {
        background: #fff;
        padding: 1.5rem 2rem;
        margin-bottom: 2rem;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    }
    
    .filter-container .btn {
        margin-bottom: 0.5rem;
    }
    
    .filter-btn {
        background: #fff;
        color: #000;
        border: 1px solid #000;
        padding: 0.85rem 1.75rem;
        transition: all 0.3s ease;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 25px;
    }
    
    .filter-btn:hover {
        background: #000;
        color: #fff;
    }
    
    .filter-btn.active {
        background: #000;
        color: #fff;
        border-color: #000;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .data-table th {
        background: #f5f5f5;
        color: #000;
        font-weight: 700;
        padding: 1.25rem 1.5rem;
        text-align: left;
        border-bottom: 2px solid #000;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .data-table td {
        padding: 1.5rem 1.5rem;
        border-bottom: 1px solid #e0e0e0;
        color: #333;
        font-size: 0.9rem;
        vertical-align: middle;
    }
    
    .data-table tr:last-child td {
        border-bottom: none;
    }
    
    .data-table tr:hover {
        background: #f5f5f5;
    }
    
    .badge-custom {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }
    
    .badge-pending {
        background: #f5f5f5;
        color: #333;
        border: 1px solid #ccc;
    }
    
    .badge-confirmed {
        background: #e0e0e0;
        color: #000;
    }
    
    .badge-preparing {
        background: #000;
        color: #fff;
    }
    
    .badge-ready {
        background: #333;
        color: #fff;
    }
    
    .badge-completed {
        background: #000;
        color: #fff;
    }
    
    .badge-cancelled {
        background: #fff;
        color: #000;
        border: 1px solid #000;
    }
    
    .badge-items {
        background: transparent;
        color: #666;
        border: 1px solid #ccc;
        padding: 0.4rem 0.75rem;
        font-size: 0.75rem;
        border-radius: 20px;
    }
    
    .view-btn {
        background: #000;
        color: #fff;
        padding: 0.65rem 1.25rem;
        border-radius: 20px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.8rem;
        font-weight: 500;
    }
    
    .view-btn:hover {
        background: #333;
        color: #fff;
    }
    
    .alert-custom {
        background: #000;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }
    
    .alert-custom .btn-close {
        filter: invert(1);
    }
    
    .empty-state {
        padding: 6rem 2rem;
        text-align: center;
    }
    
    .empty-state i {
        color: #999;
        font-size: 4rem;
        margin-bottom: 1rem;
    }
    
    .empty-state p {
        color: #666;
        font-size: 1rem;
    }
    
    .order-id {
        font-weight: 600;
        color: #000;
    }
    
    .order-total {
        font-weight: 700;
        color: #000;
    }
</style>

<div class="container-fluid" style="padding: 1rem 2rem 2.5rem;">
    <!-- Admin Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-shopping-bag" style="margin-right: 0.75rem;"></i> Orders</h1>
                <p>Manage and track all customer orders</p>
            </div>
            <div style="text-align: right;">
                <p style="margin: 0; color: #ccc;">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Status Filter -->
    <div class="filter-container">
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Orders" class="btn filter-btn @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">
                All Orders
            </a>
            <a asp-action="Orders" asp-route-status="Pending" class="btn filter-btn @(currentStatus == "Pending" ? "active" : "")">
                Pending
            </a>
            <a asp-action="Orders" asp-route-status="Confirmed" class="btn filter-btn @(currentStatus == "Confirmed" ? "active" : "")">
                Confirmed
            </a>
            <a asp-action="Orders" asp-route-status="Preparing" class="btn filter-btn @(currentStatus == "Preparing" ? "active" : "")">
                Preparing
            </a>
            <a asp-action="Orders" asp-route-status="Ready" class="btn filter-btn @(currentStatus == "Ready" ? "active" : "")">
                Ready
            </a>
            <a asp-action="Orders" asp-route-status="Completed" class="btn filter-btn @(currentStatus == "Completed" ? "active" : "")">
                Completed
            </a>
        </div>
    </div>

    <div class="section-card">
        <div class="card-header">
            <i class="fas fa-list" style="margin-right: 0.5rem;"></i> Order List
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Items</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><span class="order-id">#@order.Id</span></td>
                                <td>@order.User?.Username ?? "Guest"</td>
                                <td style="color: #666;">@order.OrderDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td><span class="order-total">@order.TotalAmount.ToString("C")</span></td>
                                <td>
                                    <span class="badge-custom @GetStatusBadgeClass(order.Status)">@order.Status</span>
                                </td>
                                <td>
                                    <span class="badge-custom badge-items">@order.OrderItems?.Count items</span>
                                </td>
                                <td>
                                    <a asp-action="OrderDetails" asp-route-id="@order.Id" class="view-btn">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-box-open"></i>
                <p>No orders found.</p>
            </div>
        }
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "badge-pending",
            "Confirmed" => "badge-confirmed",
            "Preparing" => "badge-preparing",
            "Ready" => "badge-ready",
            "Completed" => "badge-completed",
            "Cancelled" => "badge-cancelled",
            _ => "badge-completed"
        };
    }
}

