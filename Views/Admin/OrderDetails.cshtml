@model CafeWebsite.Models.Order
@{
    ViewData["Title"] = "Order #" + Model.Id;
    var statuses = new[] { "Pending", "Confirmed", "Preparing", "Ready", "Completed", "Cancelled" };
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #000 0%, #1a0f0a 50%, #0d0705 100%);
        padding: 2rem;
        margin-bottom: 2rem;
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(44, 24, 16, 0.4);
    }
    
    .admin-header h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.75rem;
        margin: 0;
    }
    
    .back-btn {
        background: #fff;
        color: #000;
        padding: 0.6rem 1.25rem;
        border-radius: 25px;
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
    }
    
    .back-btn:hover {
        background: #f5f0eb;
        color: #000;
    }
    
    .info-card {
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
        height: 100%;
    }
    
    .info-card .card-header {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 1.25rem 1.5rem;
        border: none;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }
    
    .info-card .card-body {
        padding: 1.5rem;
    }
    
    .info-card.status-card .card-header {
        background: linear-gradient(135deg, #333 0%, #6d4c41 100%);
    }
    
    .info-card.total-card .card-header {
        background: linear-gradient(135deg, #ccc 0%, #c9a277 100%);
        color: #000;
    }
    
    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid #f0ebe5;
    }
    
    .info-item:last-child {
        border-bottom: none;
    }
    
    .info-item dt {
        color: #666;
        font-weight: 500;
    }
    
    .info-item dd {
        color: #000;
        font-weight: 600;
        margin: 0;
    }
    
    .badge-custom {
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .badge-pending { background: #fff3e0; color: #e65100; border: 1px solid #ffcc80; }
    .badge-confirmed { background: #e3f2fd; color: #1565c0; border: 1px solid #90caf9; }
    .badge-preparing { background: #f3e5f5; color: #7b1fa2; border: 1px solid #ce93d8; }
    .badge-ready { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
    .badge-completed { background: #f5f5f5; color: #424242; border: 1px solid #e0e0e0; }
    .badge-cancelled { background: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
    
    .form-select-custom {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e8e0d8;
        border-radius: 12px;
        background: #faf8f5;
        color: #000;
        font-size: 0.95rem;
    }
    
    .form-select-custom:focus {
        outline: none;
        border-color: #000;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 25px;
        font-weight: 500;
        transition: all 0.3s ease;
        width: 100%;
    }
    
    .btn-primary:hover {
        background: linear-gradient(135deg, #333 0%, #000 100%);
        color: #fff;
    }
    
    .order-total {
        font-size: 2.5rem;
        font-weight: 700;
        color: #000;
    }
    
    .order-items-count {
        color: #666;
        font-size: 0.9rem;
    }
    
    .items-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .items-table th {
        background: #faf8f5;
        color: #000;
        font-weight: 700;
        padding: 1rem;
        text-align: left;
        border-bottom: 2px solid #000;
        font-size: 0.75rem;
        text-transform: uppercase;
    }
    
    .items-table td {
        padding: 1rem;
        border-bottom: 1px solid #f0ebe5;
        color: #4a4a4a;
    }
    
    .items-table tr:hover {
        background: #faf8f5;
    }
    
    .item-name {
        font-weight: 600;
        color: #000;
    }
    
    .item-price {
        font-weight: 600;
    }
    
    .subtotal {
        font-weight: 700;
        color: #000;
    }
    
    .table-footer {
        background: #faf8f5;
    }
    
    .table-footer td {
        font-weight: 700;
        color: #000;
    }
    
    .alert-success {
        background: linear-gradient(135deg, #000 0%, #333 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
    }
    
    .alert-success .btn-close {
        filter: invert(1);
    }
    
    .empty-state {
        padding: 3rem;
        text-align: center;
        color: #666;
    }
</style>

<div class="container-fluid" style="padding: 2rem;">
    <!-- Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <h1><i class="fas fa-shopping-bag" style="margin-right: 0.75rem; color: #ccc;"></i> Order #@Model.Id</h1>
            <a asp-action="Orders" class="back-btn">
                <i class="fas fa-arrow-left" style="margin-right: 0.5rem;"></i> Back to Orders
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Order Info -->
        <div class="col-md-4 mb-4">
            <div class="info-card">
                <div class="card-header">
                    <i class="fas fa-info-circle" style="margin-right: 0.5rem;"></i> Order Information
                </div>
                <div class="card-body">
                    <dl class="info-item">
                        <dt>Order ID</dt>
                        <dd>#@Model.Id</dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Date</dt>
                        <dd>@Model.OrderDate.ToString("MMM dd, yyyy")</dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Time</dt>
                        <dd>@Model.OrderDate.ToString("HH:mm")</dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Status</dt>
                        <dd><span class="badge-custom badge-@Model.Status.ToLower()">@Model.Status</span></dd>
                    </dl>
                    <dl class="info-item">
                        <dt>Customer</dt>
                        <dd>@Model.User?.Username ?? "Guest"</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Update Status -->
        <div class="col-md-4 mb-4">
            <div class="info-card status-card">
                <div class="card-header">
                    <i class="fas fa-edit" style="margin-right: 0.5rem;"></i> Update Status
                </div>
                <div class="card-body">
                    <form asp-action="UpdateOrderStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label for="status" class="form-label" style="color: #000; font-weight: 500;">New Status</label>
                            <select name="status" id="status" class="form-select-custom">
                                @foreach (var status in statuses)
                                {
                                    <option value="@status" selected="@(Model.Status == status)">@status</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save" style="margin-right: 0.5rem;"></i> Update Status
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Order Total -->
        <div class="col-md-4 mb-4">
            <div class="info-card total-card">
                <div class="card-header">
                    <i class="fas fa-coins" style="margin-right: 0.5rem;"></i> Order Total
                </div>
                <div class="card-body text-center">
                    <div class="order-total">@Model.TotalAmount.ToString("C")</div>
                    <div class="order-items-count">@Model.OrderItems?.Count items</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Items -->
    <div class="info-card">
        <div class="card-header">
            <i class="fas fa-list" style="margin-right: 0.5rem;"></i> Order Items
        </div>
        <div class="card-body" style="padding: 0;">
            @if (Model.OrderItems != null && Model.OrderItems.Any())
            {
                <div class="table-responsive">
                    <table class="items-table">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th style="text-align: right;">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td><span class="item-name">@item.MenuItem?.Name</span></td>
                                    <td><span class="item-price">@item.Price.ToString("C")</span></td>
                                    <td>@item.Quantity</td>
                                    <td style="text-align: right;"><span class="subtotal">@((item.Price * item.Quantity).ToString("C"))</span></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-footer">
                                <td colspan="3" style="text-align: right;"><strong>Total:</strong></td>
                                <td style="text-align: right;"><strong>@Model.TotalAmount.ToString("C")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-coffee" style="font-size: 2.5rem; margin-bottom: 1rem; color: #ccc;"></i>
                    <p>No items in this order.</p>
                </div>
            }
        </div>
    </div>
</div>
